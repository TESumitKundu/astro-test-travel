---
import BaseLayout from "./BaseLayout.astro";
import type { Tour } from "../lib/tours";
import { asList, formatDuration, formatInr, getTourImage } from "../lib/tours";
import { withBase } from "../lib/paths";

interface Props {
  tour: Tour;
}

const { tour } = Astro.props;
const { Content } = await tour.render();
const image = getTourImage(tour);
const seasons = asList(tour.data.season);
const travelStyles = asList(tour.data.travelStyle);
const bestMonths = asList(tour.data.bestMonths);
const placesToCover = tour.data.placesToCover ?? [];
const hasItinerary = Boolean(tour.body?.trim());
const title = tour.data.seoTitle ?? tour.data.title;
const description =
  tour.data.seoDescription ??
  `${formatDuration(tour.data.duration)} ${tour.data.place} tour from ${formatInr(tour.data.costInr)}.`;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
>
  <article>
    <header class="tour-hero" style={`--tour-image: url('${withBase(image)}')`}>
      <div class="container">
        <a class="back-link" href={withBase("/tours/")}>Back to tours</a>
      </div>
       <div class="container">
        <div class="tour-hero-content">
          <p class="eyebrow">{tour.data.place}</p>
          <h1>{tour.data.title}</h1>
          <div class="hero-tags" aria-label="Tour highlights">
            <span>{formatDuration(tour.data.duration)}</span>
            <span>{seasons.join(", ") || "All season"}</span>
            <span>{(travelStyles.length ? travelStyles : ['Leisure']).join(", ")}</span>
          </div>
        </div>
      </div>
    </header>

    <section class="section">
      <div class="container package-grid">
        <main class="package-main">
          <section class="info-panel" aria-labelledby="package-overview-title">
            <div class="section-title">
              <p class="eyebrow">Trip compass</p>
              <h2 id="package-overview-title">What to expect</h2>
            </div>
            <dl class="fact-grid">
              <div>
                <dt>Place</dt>
                <dd>{tour.data.place}</dd>
              </div>
              <div>
                <dt>Duration</dt>
                <dd>{formatDuration(tour.data.duration)}</dd>
              </div>
              <div>
                <dt>Best months</dt>
                <dd>{bestMonths.join(", ") || "Flexible"}</dd>
              </div>
              <div>
                <dt>Season</dt>
                <dd>{seasons.join(", ") || "All season"}</dd>
              </div>
              <div>
                <dt>Travel style</dt>
                <dd>{(travelStyles.length ? travelStyles : ['Leisure']).join(", ")}</dd>
              </div>
              <div>
                <dt>Group size</dt>
                <dd>Minimum {tour.data.minHeadCount} heads</dd>
              </div>
            </dl>
          </section>

          {placesToCover.length > 0 && (
            <section class="places-cover" aria-labelledby="places-cover-title">
              <div class="section-title">
                <p class="eyebrow">Route nights</p>
                <h2 id="places-cover-title">Places to cover</h2>
              </div>
              <div class="places-list">
                {placesToCover.map((place) => (
                  <article>
                    <div>
                      <strong>{place.name}</strong>
                      <span>{place.nights} {place.nights === 1 ? 'Night' : 'Nights'}</span>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          )}

          {hasItinerary && (
            <section class="itinerary-panel" aria-labelledby="itinerary-title">
              <div class="section-title">
                <p class="eyebrow">Day-wise plan</p>
                <h2 id="itinerary-title">Itinerary</h2>
              </div>
              <div class="prose itinerary">
                <Content />
              </div>
            </section>
          )}
        </main>

        <aside class="booking-card">
          <span>Starting from</span>
          <strong>{formatInr(tour.data.costInr)}</strong>
          <small>per person</small>
          <a class="button" href={withBase("/contact/")}>Enquire now</a>
        </aside>
      </div>
    </section>
    <slot name="related" />
  </article>
</BaseLayout>

<style>
  .tour-hero {
    position: relative;
    min-height: 86svh;
    padding: 38px 0 64px;
    background:
    linear-gradient(90deg, rgba(8, 24, 20, 0.64), rgba(8, 24, 20, 0.12) 58%, rgba(8, 24, 20, 0.42)),
    linear-gradient(180deg, rgba(10, 28, 24, 0.08), rgba(10, 28, 24, 0.58)),
    var(--tour-image);
    background-position: center;
    background-size: cover;
    border-radius: 0 0 34px 34px;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }
  

  .back-link {
    display: inline-flex;
    margin-bottom: 28px;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
    backdrop-filter: blur(12px);
  }


  .tour-hero-content {
    width: min(100%, 760px);
    padding-bottom: 10px;
    text-align: left;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--sun);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(3.2rem, 9vw, 7rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .hero-tags span {
    padding: 8px 12px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.92);
    font-weight: 800;
    backdrop-filter: blur(12px);
  }

  .booking-card {
    display: grid;
    gap: 6px;
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.16);
    box-shadow: 0 28px 80px rgba(8, 25, 21, 0.25);
    backdrop-filter: blur(16px);
  }

  .package-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 32px;
    align-items: start;
  }

  .package-main {
    display: grid;
    gap: 32px;
  }

  .info-panel,
  .places-cover,
  .itinerary-panel {
    padding: 34px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 30px;
    background: var(--surface-strong);
    box-shadow: 0 24px 80px rgba(23, 33, 27, 0.1);
  }

  .section-title {
    margin-bottom: 22px;
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(1.65rem, 4vw, 2.6rem);
    line-height: 1.05;
  }

  .fact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 0;
  }

  .fact-grid div {
    min-height: 124px;
    padding: 20px;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 24px;
    background:
      radial-gradient(circle at 100% 0%, rgba(243, 178, 58, 0.12), transparent 8rem),
      linear-gradient(135deg, #fffaf0, #eef8f4);
  }

  .booking-card {
    position: sticky;
    top: 92px;
    padding: 28px;
    background: linear-gradient(135deg, #fff4ea, #eef8f4);
    color: var(--ink);
    border: 1px solid rgba(239, 111, 47, 0.18);
    backdrop-filter: none;
  }

  .booking-card span,
  .booking-card small {
    color: var(--muted);
    font-weight: 900;
  }

  .booking-card strong {
    color: var(--accent-dark);
    font-size: 2.55rem;
    line-height: 1;
  }

  dt {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  dd {
    margin: 2px 0 0;
    font-weight: 700;
  }

  .places-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .places-list article {
    display: grid;
    min-height: 132px;
  }

  .places-list article div {
    display: grid;
    gap: 5px;
    align-content: end;
    padding: 22px;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 24px;
    background:
      radial-gradient(circle at 100% 0%, rgba(243, 178, 58, 0.16), transparent 8rem),
      linear-gradient(135deg, rgba(238, 248, 244, 0.96), rgba(255, 244, 234, 0.76));
    box-shadow: 0 18px 48px rgba(23, 33, 27, 0.08);
  }

  .places-list article div span {
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .places-list strong {
    color: var(--ink);
    font-family: Fraunces, Georgia, serif;
    font-size: 1.35rem;
    line-height: 1;
  }

  @media (max-width: 860px) {
    .tour-hero {
      min-height: 82svh;
      padding: 24px 0 38px;
      border-radius: 0 0 30px 30px;
    }


    .package-grid {
      grid-template-columns: 1fr;
    }

    .booking-card {
      position: static;
      order: -1;
    }

    .fact-grid {
      grid-template-columns: 1fr;
    }

    .places-list {
      grid-template-columns: 1fr;
    }
  }
</style>

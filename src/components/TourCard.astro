---
import type { Tour } from "../lib/tours";
import { asList, formatDuration, formatInr, getTourImage } from "../lib/tours";
import { withBase } from "../lib/paths";

interface Props {
  tour: Tour;
  compact?: boolean;
}

const { tour, compact = false } = Astro.props;
const image = getTourImage(tour);
const seasons = asList(tour.data.season);
const travelStyles = asList(tour.data.travelStyle);
const bestMonths = asList(tour.data.bestMonths);
---

<article
  class:list={["tour-card", { compact }]}
  data-place={tour.data.place}
  data-seasons={seasons.join(",")}
  data-styles={travelStyles.join(",")}
  data-duration={tour.data.duration.days <= 4 ? "short" : "long"}
  data-months={bestMonths.join(",")}
>
  <a
    class="image-link"
    href={withBase(`/tours/${tour.slug}/`)}
    aria-label={tour.data.title}
  >
    <img src={withBase(image)} alt="" loading="lazy" />
    <span class="image-badge">{formatDuration(tour.data.duration)}</span>
  </a>
  <div class="card-body">
    <div class="place-row">
      <p class="place-heading">{tour.data.place}</p>
      <span>{seasons.join(", ") || "All season"}</span>
    </div>

    <h3><a href={withBase(`/tours/${tour.slug}/`)}>{tour.data.title}</a></h3>
    <div class="style-row" aria-label="Travel styles">
      {
        (travelStyles.length ? travelStyles : ["Leisure"])
          .slice(0, 3)
          .map((style) => <span>{style}</span>)
      }
    </div>
    {
      !compact && (
        <p>
          Best in {bestMonths.slice(0, 3).join(", ") || "flexible months"}
          {bestMonths.length > 3 ? "..." : ""}
        </p>
      )
    }
    <div class="price-row">
      <div>
        <span>Starting from</span>
        <br />
        <strong class="pricing">{formatInr(tour.data.costInr)}</strong>
      </div>
      <span>min {tour.data.minHeadCount} heads</span>
    </div>
    <a class="read-more" href={withBase(`/tours/${tour.slug}/`)}>View tour</a>
  </div>
</article>

<style>
  .tour-card {
    position: relative;
    display: grid;
    overflow: hidden;
    min-height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 28px;
    background: var(--surface-strong);
    box-shadow: 0 22px 70px rgba(23, 33, 27, 0.12);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .tour-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 32px 90px rgba(23, 33, 27, 0.18);
  }

  .image-link {
    position: relative;
    display: block;
    overflow: hidden;
  }

  .image-link img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  .image-link::after {
    position: absolute;
    inset: auto 0 0;
    height: 48%;
    content: "";
    background: linear-gradient(180deg, transparent, rgba(8, 24, 20, 0.58));
    pointer-events: none;
  }

  .image-badge {
    position: absolute;
    left: 14px;
    bottom: 14px;
    z-index: 1;
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 12px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 900;
    backdrop-filter: blur(12px);
  }

  .tour-card:hover .image-link img {
    transform: scale(1.035);
  }

  .card-body {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .place-heading {
    margin: 0;
    color: var(--accent-dark);
    font-family: var(--ff-head);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
  }

  .place-row,
  .price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .place-row > span {
    padding: 5px 10px;
    border-radius: 999px;
    background: #eef8f4;
    color: var(--green);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .style-row {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .style-row span {
    padding: 5px 9px;
    border: 1px solid rgba(15, 118, 110, 0.16);
    border-radius: 999px;
    background: #eef8f4;
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 900;
  }

  strong.pricing {
    color: var(--accent-dark);
  }

  h3 {
    margin: 0;
    font-size: 1.42rem;
    font-weight: 700;
    line-height: 1.08;
    color: var(--ink);
  }

  h3 a,
  .read-more {
    text-decoration: none;
  }

  h3 a:hover,
  .read-more:hover {
    color: var(--accent);
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  strong {
    color: var(--ink);
    font-size: 1.22rem;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-radius: 16px;
    background: #fff4ea;
    color: var(--accent-dark);
    font-weight: 800;
  }

  .read-more:hover {
    background: var(--accent);
    color: #fff;
  }

  .compact .card-body {
    padding: 16px;
  }

  @media (max-width: 620px) {
    .tour-card {
      border-radius: 22px;
      box-shadow: 0 14px 40px rgba(23, 33, 27, 0.12);
    }

    .image-link img {
      aspect-ratio: 1.22 / 1;
    }

    .read-more {
      min-height: 48px;
      border-radius: 16px;
    }
  }
</style>

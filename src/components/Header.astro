---
import site from '../../config/site.json';
import { withBase } from '../lib/paths';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')} aria-label={site.siteName}>
      <img src={withBase(site.logo)} alt="" width="38" height="38" />
      <span>{site.siteName}</span>
    </a>
    <nav aria-label="Primary navigation">
      <a href={withBase('/')}>Home</a>
      <a href={withBase('/tours/')}>Tours</a>
      <a href={withBase('/about/')}>About</a>
      <a href={withBase('/contact/')}>Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(232, 221, 201, 0.8);
    background: rgba(251, 248, 241, 0.9);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    display: flex;
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px 20px;
  }

  nav a {
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    color: var(--muted);
    font-weight: 700;
    text-decoration: none;
  }

  nav a:hover {
    background: #fff4ea;
    color: var(--accent);
  }

  @media (max-width: 560px) {
    .site-header {
      top: auto;
      bottom: 12px;
      width: calc(100% - 24px);
      margin-inline: 12px;
      border: 1px solid rgba(232, 221, 201, 0.92);
      border-radius: 22px;
      box-shadow: 0 18px 42px rgba(23, 33, 27, 0.16);
    }

    .header-inner {
      min-height: 64px;
      padding: 8px 12px;
    }

    .brand span {
      display: none;
    }

    .brand img {
      width: 34px;
      height: 34px;
    }

    nav {
      flex: 1;
      justify-content: space-around;
      gap: 4px;
    }

    nav a {
      min-height: 42px;
      padding: 0 8px;
      color: var(--ink);
      font-size: 0.86rem;
    }
  }
</style>

---
import TourCard from './TourCard.astro';
import type { Tour } from '../lib/tours';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  tours: Tour[];
  viewAllLink?: string;
  carousel?: boolean;
}

const { title, tours, viewAllLink = '/tours/', carousel = false } = Astro.props;
---

<section class:list={['tour-section', { carousel }]}>
  <div class="section-head">
    <h2>{title}</h2>
    <a href={withBase(viewAllLink)}>View all</a>
  </div>
  <div class={carousel ? 'tour-strip' : 'tour-grid'}>
    {tours.map((tour) => <TourCard tour={tour} compact={carousel} />)}
  </div>
</section>

<style>
  .tour-section + .tour-section {
    margin-top: 64px;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 24px;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: 0;
  }

  .section-head a {
    color: var(--accent);
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .tour-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .tour-strip {
    display: grid;
    grid-auto-columns: minmax(260px, 34%);
    grid-auto-flow: column;
    gap: 18px;
    overflow-x: auto;
    padding-bottom: 12px;
    scroll-snap-type: x proximity;
  }

  .tour-strip :global(.tour-card) {
    scroll-snap-align: start;
  }

  @media (max-width: 900px) {
    .tour-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tour-strip {
      grid-auto-columns: minmax(260px, 72%);
    }
  }

  @media (max-width: 620px) {
    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .tour-grid {
      grid-template-columns: 1fr;
    }

    .tour-strip {
      grid-auto-columns: minmax(250px, 88%);
    }
  }
</style>

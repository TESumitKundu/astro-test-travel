---
import site from '../../config/site.json';
import { withBase } from '../lib/paths';
const links = Object.entries(site.socialLinks).filter(([, href]) => href);
const socialIcons: Record<string, string> = {
  facebook: 'f',
  instagram: 'ig',
  twitter: 'x',
  linkedin: 'in'
};
---

<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-top">
      <a class="footer-brand" href={withBase('/')}>
        <img src={withBase(site.logo)} alt="" width="38" height="38" />
        <span>{site.siteName}</span>
      </a>
      <p>{site.siteDescription}</p>
    </div>

    <div class="footer-columns">
      <div class="footer-links">
        <h2>Explore</h2>
        <a href={withBase('/')}>Home</a>
        <a href={withBase('/tours/')}>Tours</a>
        <a href={withBase('/about/')}>About</a>
        <a href={withBase('/contact/')}>Contact</a>
      </div>
      <div class="footer-links">
        <h2>Contact</h2>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={`tel:${site.phone}`}>{site.phone}</a>
      </div>
      <div class="footer-links">
        <h2>Social media</h2>
        <div class="social-list" aria-label="Social media links">
          {links.map(([name, href]) => (
            <a href={href} aria-label={name}>
              <b aria-hidden="true">{socialIcons[name] ?? name.slice(0, 2)}</b>
              <span>{name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
  <div class="container copyright">
    <span>&copy; {new Date().getFullYear()} {site.siteName}. Tours managed with Git-based content.</span>
  </div>
</footer>

<style>
  .site-footer {
    background:
      radial-gradient(circle at 14% 8%, rgba(243, 178, 58, 0.18), transparent 22rem),
      radial-gradient(circle at 88% 12%, rgba(13, 117, 111, 0.2), transparent 24rem),
      linear-gradient(135deg, #071411 0%, #102f2b 58%, #0b1714 100%);
    color: #f9fafb;
    border-radius: 34px 34px 0 0;
  }

  .site-footer .footer-shell {
    display: grid;
    gap: 40px;
    padding: 66px 0 44px;
  }

  .site-footer .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    padding-bottom: 34px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-footer .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 34px;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-size: 1.15rem;
    font-weight: 900;
    text-decoration: none;
  }

  .footer-brand img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
  }

  p {
    max-width: 460px;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.05rem;
  }

  h2 {
    margin: 0 0 12px;
    color: #fff;
    font-size: 1.05rem;
  }

  a {
    display: inline-flex;
    width: fit-content;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    text-transform: capitalize;
  }

  a:hover {
    color: #fff;
  }

  a + a {
    margin-top: 8px;
  }

  .site-footer .footer-links {
    display: grid;
    align-content: start;
    gap: 8px;
  }

  .site-footer .social-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .site-footer .social-list a {
    align-items: center;
    gap: 7px;
    padding: 7px 12px 7px 7px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.09);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .site-footer .social-list b {
    display: inline-grid;
    place-items: center;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--sun));
    color: #fff;
    font-size: 0.72rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .copyright {
    padding: 18px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.92rem;
  }

  @media (max-width: 760px) {
    .site-footer {
      margin: 12px;
      border-radius: 30px;
    }

    .site-footer .footer-top {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer .footer-columns {
      grid-template-columns: 1fr;
    }
  }
</style>

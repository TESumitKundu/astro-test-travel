---
import site from '../../config/site.json';
import { withBase } from '../lib/paths';
const links = Object.entries(site.socialLinks);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href={withBase('/')}>
        <img src={withBase(site.logo)} alt="" width="38" height="38" />
        <span>{site.siteName}</span>
      </a>
      <p>{site.siteDescription}</p>
    </div>
    <div>
      <h2>Contact</h2>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={`tel:${site.phone}`}>{site.phone}</a>
    </div>
    <div>
      <h2>Social</h2>
      {links.map(([name, href]) => <a href={href}>{name}</a>)}
    </div>
  </div>
  <div class="container copyright">
    <span>&copy; {new Date().getFullYear()} {site.siteName}. Tours managed with Git-based content.</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    background: #111827;
    color: #f9fafb;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 36px;
    padding: 52px 0;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }

  p {
    max-width: 460px;
    color: #cbd5e1;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1rem;
  }

  a {
    display: block;
    color: #cbd5e1;
    text-decoration: none;
    text-transform: capitalize;
  }

  a + a {
    margin-top: 8px;
  }

  .copyright {
    padding: 18px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: #94a3b8;
    font-size: 0.92rem;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

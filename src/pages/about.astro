---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const about = (await getCollection('pages')).find((page) => page.slug === 'about');

if (!about) {
  throw new Error('Missing about page content.');
}

const { Content } = await about.render();
---

<BaseLayout
  title={about.data.seoTitle ?? about.data.title}
  description={about.data.seoDescription ?? 'About this Astro Git CMS website.'}
>
  <section class="page-head">
    <div class="container">
      <h1>{about.data.title}</h1>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: 70px 0;
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    line-height: 1;
    letter-spacing: 0;
  }
</style>

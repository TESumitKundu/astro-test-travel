---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TourCard from '../../components/TourCard.astro';
import { getAllMonths, getAllPlaces, getAllSeasons, getAllTours, getAllTravelStyles } from '../../lib/tours';
import { withBase } from '../../lib/paths';

const tours = await getAllTours();
const places = await getAllPlaces();
const seasons = await getAllSeasons();
const travelStyles = await getAllTravelStyles();
const months = getAllMonths();
---

<BaseLayout title="Tours" description="Browse India tour packages by place, duration, month, season, and travel style.">
  <section class="page-head" style={`--page-hero-image: url('${withBase('/uploads/tour-ladakh.svg')}')`}>
    <div class="container">
      <p class="eyebrow">Find your route</p>
      <h1>Choose a tour that fits your calendar</h1>
      <p>Filter by destination, duration, season, travel style, and the month you want to travel.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <form class="filters" data-tour-filters>
        <div class="filter-title">
          <strong>Trip finder</strong>
          <span>Adjust filters to narrow the list instantly.</span>
        </div>
        <label>
          <span>Place</span>
          <select name="place">
            <option value="">All places</option>
            {places.map((place) => <option value={place}>{place}</option>)}
          </select>
        </label>
        <label>
          <span>Duration</span>
          <select name="duration">
            <option value="">All durations</option>
            <option value="short">Short: 4 days or less</option>
            <option value="long">Long: 5 days or more</option>
          </select>
        </label>
        <label>
          <span>Month</span>
          <select name="month">
            <option value="">All months</option>
            {months.map((month) => <option value={month}>{month}</option>)}
          </select>
        </label>
        <label>
          <span>Season</span>
          <select name="season">
            <option value="">All seasons</option>
            {seasons.map((season) => <option value={season}>{season}</option>)}
          </select>
        </label>
        <label>
          <span>Travel style</span>
          <select name="style">
            <option value="">All styles</option>
            {travelStyles.map((style) => <option value={style}>{style}</option>)}
          </select>
        </label>
        <button type="reset">Reset filters</button>
      </form>

      <p class="result-count" data-result-count>{tours.length} tours found</p>

      <div class="tour-grid" data-tour-grid>
        {tours.map((tour) => <TourCard tour={tour} />)}
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector('[data-tour-filters]');
    const cards = [...document.querySelectorAll('[data-tour-grid] .tour-card')];
    const count = document.querySelector('[data-result-count]');
    const params = new URLSearchParams(window.location.search);

    if (form instanceof HTMLFormElement) {
      for (const [key, value] of params.entries()) {
        const field = form.elements.namedItem(key);
        if (field instanceof HTMLSelectElement) {
          field.value = value;
        }
      }

      const applyFilters = () => {
        const data = new FormData(form);
        const place = String(data.get('place') ?? '');
        const duration = String(data.get('duration') ?? '');
        const month = String(data.get('month') ?? '');
        const season = String(data.get('season') ?? '');
        const style = String(data.get('style') ?? '');
        let visible = 0;

        cards.forEach((card) => {
          const months = (card.getAttribute('data-months') ?? '').split(',');
          const seasons = (card.getAttribute('data-seasons') ?? '').split(',');
          const styles = (card.getAttribute('data-styles') ?? '').split(',');
          const matches =
            (!place || card.getAttribute('data-place') === place) &&
            (!duration || card.getAttribute('data-duration') === duration) &&
            (!month || months.includes(month)) &&
            (!season || seasons.includes(season)) &&
            (!style || styles.includes(style));

          card.toggleAttribute('hidden', !matches);
          if (matches) visible += 1;
        });

        if (count) {
          count.textContent = `${visible} ${visible === 1 ? 'tour' : 'tours'} found`;
        }

        const nextParams = new URLSearchParams();
        for (const [key, value] of data.entries()) {
          if (value) nextParams.set(key, String(value));
        }
        const query = nextParams.toString();
        history.replaceState(null, '', query ? `?${query}` : window.location.pathname);
      };

      form.addEventListener('change', applyFilters);
      form.addEventListener('reset', () => setTimeout(applyFilters));
      applyFilters();
    }
  </script>
</BaseLayout>

<style>
  .page-head {
    min-height: 58svh;
    display: grid;
    align-items: end;
    padding: 120px 0 72px;
    background:
      linear-gradient(90deg, rgba(8, 24, 20, 0.64), rgba(8, 24, 20, 0.14) 58%, rgba(8, 24, 20, 0.44)),
      var(--page-hero-image, none);
    background-position: center;
    background-size: cover;
    border-radius: 0 0 34px 34px;
    color: #fff;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--sun);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.4rem);
    line-height: 0.94;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .page-head p {
    max-width: 660px;
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.12rem;
  }

  .filters {
    display: grid;
    grid-template-columns: minmax(220px, 1.2fr) repeat(5, minmax(0, 1fr)) auto;
    gap: 14px;
    align-items: end;
    margin-top: -64px;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 28px;
    background: rgba(255, 253, 248, 0.92);
    box-shadow: 0 28px 90px rgba(23, 33, 27, 0.16);
    backdrop-filter: blur(18px);
  }

  .filter-title {
    display: grid;
    gap: 3px;
  }

  .filter-title strong {
    font-size: 1.12rem;
  }

  .filter-title span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  label {
    display: grid;
    gap: 6px;
    color: var(--green);
    font-weight: 800;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  select,
  button {
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-strong);
    color: var(--ink);
    font: inherit;
  }

  select {
    width: 100%;
    padding: 0 10px;
  }

  button {
    padding: 0 16px;
    border-color: #ffe2c8;
    background: #fff4ea;
    color: var(--accent-dark);
    cursor: pointer;
    font-weight: 800;
    white-space: nowrap;
  }

  .result-count {
    margin: 24px 0 16px;
    color: var(--muted);
    font-weight: 800;
  }

  .tour-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
  }

  .tour-grid :global(.tour-card[hidden]) {
    display: none;
  }

  @media (max-width: 940px) {
    .filters {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: -30px;
    }

    .filter-title,
    .filters button {
      grid-column: 1 / -1;
    }

    .tour-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .page-head {
      min-height: 62svh;
      padding: 54px 0 92px;
      border-radius: 0 0 28px 28px;
    }

    .filters {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: -72px;
      padding: 14px;
      border-radius: 24px;
    }

    .tour-grid {
      grid-template-columns: 1fr;
    }

    .filter-title,
    .filters button {
      grid-column: 1 / -1;
    }

    select,
    button {
      min-height: 52px;
      border-radius: 18px;
    }

    .result-count {
      padding: 0 2px;
    }
  }
</style>

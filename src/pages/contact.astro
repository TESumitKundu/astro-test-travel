---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

const mailSubject = encodeURIComponent('Travel enquiry');
const mailBody = encodeURIComponent(
  'Hello TrailNest Tours,\n\nI would like help planning a trip.\n\nDestination:\nTravel month:\nDuration:\nHead count:\nBudget:\nNotes:\n'
);
const socialLinks = Object.entries(site.socialLinks).filter(([, href]) => href);
const socialIcons: Record<string, string> = {
  facebook: 'f',
  instagram: 'ig',
  twitter: 'x',
  linkedin: 'in'
};
---

<BaseLayout title="Contact" description="Contact TrailNest Tours for custom tour planning and travel enquiries.">
  <section class="contact-hero">
    <div class="container contact-hero-grid">
      <div>
        <p class="eyebrow">Contact us</p>
        <h1>Tell us what kind of trip you have in mind.</h1>
        <p>Share your destination, month, group size, budget, and travel style. We will help narrow the route and suggest the right tours or stays.</p>
      </div>
      <div class="quick-card">
        <span>Fastest way</span>
        <a href={`tel:${site.phone}`}>{site.phone}</a>
        <a href={`mailto:${site.email}?subject=${mailSubject}&body=${mailBody}`}>{site.email}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <form class="contact-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
        <label>
          <span>Name</span>
          <input name="name" type="text" placeholder="Your name" required />
        </label>
        <label>
          <span>Email</span>
          <input name="email" type="email" placeholder="you@example.com" required />
        </label>
        <label>
          <span>Phone</span>
          <input name="phone" type="tel" placeholder="+91" />
        </label>
        <label>
          <span>Travel month</span>
          <input name="travel_month" type="text" placeholder="January, summer, flexible..." />
        </label>
        <label class="wide">
          <span>Message</span>
          <textarea name="message" rows="6" placeholder="Tell us destination, duration, head count, budget, and travel style."></textarea>
        </label>
        <button type="submit">Send enquiry</button>
      </form>

      <aside class="contact-info">
        <article>
          <span>Email</span>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </article>
        <article>
          <span>Phone</span>
          <a href={`tel:${site.phone}`}>{site.phone}</a>
        </article>
        <article>
          <span>Social media</span>
          <div class="social-links">
            {socialLinks.map(([name, href]) => (
              <a href={href} aria-label={name}>
                <b aria-hidden="true">{socialIcons[name] ?? name.slice(0, 2)}</b>
                <span>{name}</span>
              </a>
            ))}
          </div>
        </article>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: 88px 0;
    background:
      radial-gradient(circle at 88% 16%, rgba(246, 183, 60, 0.2), transparent 18rem),
      linear-gradient(135deg, #113c35, #0f766e);
    color: #fff;
  }

  .contact-hero-grid,
  .contact-grid {
    display: grid;
    gap: 34px;
  }

  .contact-hero-grid {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.5fr);
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--sun);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1;
  }

  .contact-hero p {
    max-width: 680px;
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.12rem;
  }

  .quick-card {
    display: grid;
    gap: 12px;
    padding: 26px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(12px);
  }

  .quick-card span {
    color: var(--sun);
    font-weight: 900;
    text-transform: uppercase;
  }

  .quick-card a {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 900;
    text-decoration: none;
  }

  .contact-grid {
    grid-template-columns: minmax(0, 1fr) 320px;
    align-items: start;
  }

  .contact-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 28px;
    background: #fff;
    box-shadow: 0 24px 70px rgba(23, 33, 27, 0.1);
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #fff;
    color: var(--ink);
    font: inherit;
    font-weight: 700;
  }

  input {
    min-height: 52px;
    padding: 0 14px;
  }

  textarea {
    resize: vertical;
    padding: 14px;
  }

  .wide,
  button {
    grid-column: 1 / -1;
  }

  button {
    min-height: 56px;
    border: 0;
    border-radius: 18px;
    background: var(--accent);
    color: #fff;
    font: inherit;
    font-weight: 900;
    cursor: pointer;
  }

  .contact-info {
    display: grid;
    gap: 14px;
  }

  .contact-info article {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: #fff;
  }

  .contact-info span {
    display: block;
    margin-bottom: 8px;
    color: var(--muted);
    font-weight: 900;
    text-transform: uppercase;
  }

  .contact-info a {
    color: var(--accent-dark);
    font-weight: 900;
    text-decoration: none;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 7px 12px 7px 7px;
    border: 1px solid #ffe2c8;
    border-radius: 999px;
    background: #fff4ea;
    color: var(--accent-dark);
    font-size: 0.9rem;
    text-transform: capitalize;
  }

  .social-links b {
    display: inline-grid;
    place-items: center;
    min-width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 0.76rem;
    line-height: 1;
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    .contact-hero {
      padding: 54px 0;
      border-radius: 0 0 28px 28px;
    }

    .contact-hero-grid,
    .contact-grid,
    .contact-form {
      grid-template-columns: 1fr;
    }

    .wide,
    button {
      grid-column: auto;
    }
  }
</style>

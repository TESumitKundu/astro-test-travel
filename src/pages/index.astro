  <section class="section hotels-section">
    <div class="container">
      <div class="hotel-head">
        <div>
          <p class="eyebrow">Stay ideas</p>
          <h2>Hotels to pair with your route</h2>
        </div>
        {
          hasMultipleHotels && (
            <div class="hotel-controls" aria-label="Hotel carousel controls">
              <button type="button" data-hotel-prev aria-label="Previous hotel">
                Prev
              </button>
              <button type="button" data-hotel-next aria-label="Next hotel">
                Next
              </button>
            </div>
          )
        }
      </div>
      <div class="hotel-carousel" data-hotel-carousel>
        <div class="hotel-track">
          {
            hotels.map((hotel, index) => (
              <article
                class:list={["hotel-slide", { active: index === 0 }]}
                data-hotel-slide
              >
                <div
                  class="hotel-gallery"
                  aria-label={`${hotel.data.name} images`}
                >
                  {hotel.data.images.map((image, imageIndex) => (
                    <img
                      class={`image-${imageIndex + 1}`}
                      src={withBase(image)}
                      alt=""
                      loading="lazy"
                    />
                  ))}
                </div>
                <div class="hotel-body">
                  <span>{hotel.data.place}</span>
                  <h3>{hotel.data.name}</h3>
                  <p>{hotel.data.note}</p>
                  <div class="hotel-meta">
                    <strong>
                      {formatInr(hotel.data.startingRoomPriceInr)}
                    </strong>
                    <small>starting room price / night</small>
                  </div>
                  {hotel.data.website ? (
                    <a
                      href={hotel.data.website}
                      target="_blank"
                      rel="noreferrer"
                    >
                      Visit website
                    </a>
                  ) : (
                    <em>Website coming soon</em>
                  )}
                </div>
              </article>
            ))
          }
        </div>
        {
          hasMultipleHotels && (
            <div class="hotel-dots" aria-label="Hotel slides">
              {hotels.map((hotel, index) => (
                <button
                  class:list={{ active: index === 0 }}
                  type="button"
                  data-hotel-dot
                  aria-label={`Show ${hotel.data.name}`}
                />
              ))}
            </div>
          )
        }
      </div>
    </div>
    <script>
      const carousel = document.querySelector("[data-hotel-carousel]");

      if (carousel) {
        const slides = [
          ...carousel.querySelectorAll<HTMLElement>("[data-hotel-slide]"),
        ];
        const dots = [
          ...carousel.querySelectorAll<HTMLButtonElement>("[data-hotel-dot]"),
        ];
        const prev = document.querySelector("[data-hotel-prev]");
        const next = document.querySelector("[data-hotel-next]");
        let active = 0;

        const showSlide = (index: number) => {
          active = (index + slides.length) % slides.length;

          slides.forEach((slide: HTMLElement, slideIndex: number) => {
            const isActive = slideIndex === active;
            slide.classList.toggle("active", isActive);
            slide.setAttribute("aria-hidden", String(!isActive));
          });

          dots.forEach((dot: HTMLButtonElement, dotIndex: number) => {
            dot.classList.toggle("active", dotIndex === active);
          });
        };

        prev?.addEventListener("click", () => showSlide(active - 1));
        next?.addEventListener("click", () => showSlide(active + 1));
        dots.forEach((dot: HTMLButtonElement, index: number) =>
          dot.addEventListener("click", () => showSlide(index)),
        );
        showSlide(0);
      }
    </script>
  </section>

  <section class="custom-hero">
    <div class="container custom-grid">
      <div>
        <p class="eyebrow">Custom route</p>
        <h2>Need a private plan for your group?</h2>
        <p>
          Tell us your dates, head count, budget, and travel style. We can shape
          a custom itinerary around family trips, pilgrimages, mountain breaks,
          or mixed destination plans.
        </p>
      </div>
      <a class="button" href={withBase("/contact/")}>Contact us</a>
    </div>
  </section>
  <script>
    const hero = document.querySelector<HTMLElement>("[data-travel-hero]");
    const clampProgress = (value: number, min = 0, max = 1) =>
      Math.min(Math.max(value, min), max);

    const cubicBezier =
      (x1: number, y1: number, x2: number, y2: number) => (value: number) => {
        const x = clampProgress(value);
        let t = x;

        for (let index = 0; index < 5; index++) {
          const inv = 1 - t;
          const estimate =
            3 * inv * inv * t * x1 + 3 * inv * t * t * x2 + t * t * t;
          const derivative =
            3 * inv * inv * x1 + 6 * inv * t * (x2 - x1) + 3 * t * t * (1 - x2);
          if (derivative === 0) break;
          t = clampProgress(t - (estimate - x) / derivative);
        }

        const inv = 1 - t;
        return 3 * inv * inv * t * y1 + 3 * inv * t * t * y2 + t * t * t;
      };

    const easeScroll = cubicBezier(0.15, 0.61, 0, 1);

    const getSectionProgress = (element: HTMLElement) => {
      const rect = element.getBoundingClientRect();
      const distance = Math.max(rect.height - window.innerHeight, 1);
      return clampProgress(-rect.top / distance);
    };

    const updateScrollMotion = () => {
      if (hero) {
        const progress = getSectionProgress(hero);
        const cards = [
          ...hero.querySelectorAll<HTMLElement>("[data-travel-image]"),
        ];
        const copy = [
          ...hero.querySelectorAll<HTMLElement>("[data-travel-copy]"),
        ];
        const itemCount = cards.length + copy.length + 1;
        const stagger = 0.08;
        const total = 1 + stagger * Math.max(itemCount - 1, 0);
        const maskProgress = easeScroll(clampProgress(progress * total));
        const uiOpacity = 1 - clampProgress(progress / 0.18);

        hero.style.setProperty("--progress", progress.toFixed(4));
        hero.style.setProperty("--mask-progress", maskProgress.toFixed(4));
        hero.style.setProperty("--ui-opacity", uiOpacity.toFixed(4));

        cards.forEach((card, index) => {
          const itemProgress = clampProgress(
            progress * total - stagger * (index + 1),
          );
          card.style.setProperty(
            "--image-progress",
            easeScroll(itemProgress).toFixed(4),
          );
        });

        copy.forEach((item, index) => {
          const itemProgress = clampProgress(
            progress * total - stagger * (cards.length + index + 1),
          );
          item.style.setProperty(
            "--image-progress",
            easeScroll(itemProgress).toFixed(4),
          );
        });
      }

    };

    updateScrollMotion();
    window.addEventListener("scroll", updateScrollMotion, { passive: true });
    window.addEventListener("resize", updateScrollMotion);
    window.addEventListener("travel-month-gallery-ready", updateScrollMotion);
  </script>
</BaseLayout>


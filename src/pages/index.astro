  .mini-stats b {
    display: block;
    color: #fff;
    font-size: 1.4rem;
    line-height: 1;
  }

  .month-section {
    padding-bottom: 44px;
  }

  .client-month-tours .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 24px;
  }

  .client-month-tours .section-head h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .client-month-tours .section-head a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #fff4ea;
    color: var(--accent-dark);
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .client-month-tours .tour-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  :global(.month-loading) {
    grid-column: 1 / -1;
    margin: 0;
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 24px;
    background: var(--surface-strong);
    color: var(--muted);
    font-weight: 800;
  }

  :global(.month-tour-card) {
    position: relative;
    display: grid;
    overflow: hidden;
    min-height: 100%;
    min-height: 520px;
    border: 0;
    border-radius: 16px;
    background: #071411;
    box-shadow: 0 22px 70px rgba(23, 33, 27, 0.12);
    color: #fff;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  :global(.month-tour-card:hover) {
    transform: translateY(-3px);
    box-shadow: 0 32px 90px rgba(23, 33, 27, 0.18);
  }

  :global(.month-image-link) {
    position: absolute;
    inset: 0;
    display: grid;
    overflow: hidden;
  }

  :global(.month-image-link img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  :global(.month-image-link::after) {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(180deg, rgba(7, 20, 17, 0.02), rgba(7, 20, 17, 0.5)),
      linear-gradient(90deg, rgba(7, 20, 17, 0.18), transparent 62%);
    pointer-events: none;
  }

  :global(.month-tour-card:hover .month-image-link img) {
    transform: scale(1.035);
  }

  :global(.month-card-body) {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 12px;
    align-content: end;
    padding: 24px;
  }

  :global(.month-place-heading) {
    margin: 0;
    color: var(--sun);
    font-family: var(--ff-head);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
  }

  :global(.month-place-row),
  :global(.month-price-row) {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.84rem;
    font-weight: 800;
  }

  :global(.month-place-row > span) {
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.month-style-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  :global(.month-style-row span) {
    padding: 6px 10px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 900;
  }

  :global(.month-card-body h3) {
    margin: 0;
    color: #fff;
    font-size: clamp(1.35rem, 2.1vw, 1.9rem);
    font-weight: 700;
    line-height: 1.05;
  }

  :global(.month-card-body p) {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
  }

  :global(.month-price-row strong) {
    color: #fff;
    font-size: 1.22rem;
  }

  .planner-band {
    padding: 70px 0;
    /* background:
      radial-gradient(
        circle at 12% 18%,
        rgba(243, 178, 58, 0.22),
        transparent 20rem
      ),
      radial-gradient(
        circle at 92% 20%,
        rgba(13, 117, 111, 0.16),
        transparent 22rem
      ),
      linear-gradient(135deg, #fff8e9 0%, #eef8f4 58%, #fffdf8 100%); */
    position: relative;
    color: var(--ink);
  }

  .trip-planner {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.2fr);
    gap: 0;
    overflow: hidden;
    border: 1px solid rgba(232, 221, 201, 0.9);
    border-radius: 34px;
    background: rgba(255, 253, 248, 0.92);
    box-shadow: 0 34px 100px rgba(23, 33, 27, 0.16);
  }

  .planner-copy {
    display: grid;
    align-content: center;
    min-height: 300px;
    padding: 34px;
    background:
      radial-gradient(
        circle at 0% 0%,
        rgba(243, 178, 58, 0.16),
        transparent 18rem
      ),
      #0b332d;
    color: #fff;
  }

  .planner-copy h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.15;
  }

  .planner-copy p:not(.eyebrow) {
    margin: 12px 0 0;
    color: rgba(255, 255, 255, 0.78);
  }

  .planner-copy .eyebrow {
    margin-bottom: 5px;
    color: var(--sun);
    font-size: 0.78rem;
  }

  .planner-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    padding: 22px;
    align-content: center;
  }

  .planner-field,
  .trip-planner :global(label.planner-field) {
    display: grid;
    padding: 14px;
    border: 1px solid rgba(232, 221, 201, 0.9);
    border-radius: 22px;
    background: var(--surface-strong);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.38);
  }

  .planner-field span,
  .trip-planner :global(label.planner-field > span) {
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .planner-field select,
  .trip-planner :global(label.planner-field select) {
    width: 100%;
    min-height: 42px;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-weight: 800;
  }

  .planner-field.wide {
    grid-column: span 2;
  }

  .trip-planner button,
  .trip-planner :global(.planner-fields > button) {
    min-height: 56px;
    border: 0;
    border-radius: 999px;
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
    font: inherit;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 16px 34px rgba(200, 77, 22, 0.22);
  }

  .planner-live-results {
    display: grid;
    gap: 12px;
    padding: 16px;
    border: 1px solid rgba(232, 221, 201, 0.9);
    background: var(--surface-strong);
  }

  .planner-live-results {
    grid-column: 1 / -1;
    grid-template-columns: minmax(180px, 0.35fr) minmax(0, 0.65fr);
    align-items: center;
    border-radius: 22px;
  }

  .planner-live-results p {
    margin: 0 0 4px;
    color: var(--ink);
    font-size: 1.12rem;
    font-weight: 900;
  }

  .planner-live-results small {
    color: var(--muted);
    font-weight: 800;
  }

  .planner-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  :global(.planner-preview-card) {
    position: relative;
    overflow: hidden;
    min-height: 116px;
    border-radius: 14px;
    color: #fff;
    text-decoration: none;
  }

  :global(.planner-preview-card img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.planner-preview-card::after) {
    position: absolute;
    inset: 0;
    content: "";
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.62));
  }

  :global(.planner-preview-card span) {
    position: absolute;
    z-index: 1;
    right: 10px;
    bottom: 10px;
    left: 10px;
  }

  :global(.planner-preview-card b),
  :global(.planner-preview-card small) {
    display: block;
  }

  :global(.planner-preview-card b) {
    font-size: 0.88rem;
    line-height: 1.05;
  }

  :global(.planner-preview-card small) {
    margin-top: 4px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .interactive-planner {
    overflow: visible;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .interactive-planner .planner-copy {
    position: relative;
    z-index: 3;
    border-radius: 24px 0 0 24px;
    box-shadow: 0 30px 80px rgba(7, 20, 17, 0.14);
  }

  .interactive-planner .planner-fields {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    overflow: visible;
    padding: 0;
    align-content: center;
    isolation: isolate;
  }

  .interactive-planner .planner-field,
  .interactive-planner :global(label.planner-field) {
    position: relative;
    display: grid;
    grid-template-columns: minmax(180px, 0.58fr) minmax(180px, 0.42fr);
    align-items: center;
    min-height: 92px;
    margin: -1px 0 0;
    padding: 18px 28px;
    overflow: visible;
    border: 0;
    border-radius: 0;
    background: #dedede;
    box-shadow: none;
    color: var(--ink);
    transition:
      background 0.26s ease,
      color 0.26s ease,
      opacity 0.26s ease,
      transform 0.26s ease,
      z-index 0s linear 0.26s;
    clip-path: polygon(0 0, calc(100% - 38px) 0, 100% 45%, 100% 100%, 0 100%);
  }

  .interactive-planner .planner-field:nth-of-type(odd),
  .interactive-planner :global(label.planner-field:nth-of-type(odd)) {
    background: #f2f2f0;
  }

  .interactive-planner .planner-field:nth-of-type(2),
  .interactive-planner :global(label.planner-field:nth-of-type(2)) {
    margin-left: clamp(22px, 4vw, 68px);
  }

  .interactive-planner .planner-field:nth-of-type(3),
  .interactive-planner :global(label.planner-field:nth-of-type(3)) {
    margin-right: clamp(28px, 8vw, 130px);
  }

  .interactive-planner .planner-field:nth-of-type(4),
  .interactive-planner :global(label.planner-field:nth-of-type(4)) {
    margin-left: clamp(58px, 10vw, 180px);
  }

  .interactive-planner .planner-field:nth-of-type(5),
  .interactive-planner :global(label.planner-field:nth-of-type(5)) {
    margin-right: clamp(14px, 5vw, 90px);
  }

  .interactive-planner .planner-fields:has(.planner-field:hover) .planner-field:not(:hover),
  .interactive-planner .planner-fields:has(.planner-field:focus-within) .planner-field:not(:focus-within) {
    color: rgba(23, 25, 19, 0.18);
    opacity: 0.52;
  }

  .interactive-planner .planner-field:hover,
  .interactive-planner .planner-field:focus-within,
  .interactive-planner :global(label.planner-field:hover),
  .interactive-planner :global(label.planner-field:focus-within) {
    z-index: 7;
    background: #b6b6b4;
    color: var(--ink);
    transform: translateX(-12px) scale(1.02);
    transition-delay: 0s;
  }

  .interactive-planner .planner-field:nth-of-type(1):hover,
  .interactive-planner .planner-field:nth-of-type(1):focus-within {
    background: var(--sun);
  }

  .interactive-planner .planner-title,
  .interactive-planner :global(label.planner-field > .planner-title) {
    color: currentColor;
    font-family: var(--display-font);
    font-size: clamp(1.9rem, 3.15vw, 3.45rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0;
    text-transform: none;
  }

  .interactive-planner .planner-field select,
  .interactive-planner :global(label.planner-field select) {
    position: relative;
    z-index: 3;
    min-height: 46px;
    padding: 0 14px;
    border: 1px solid rgba(23, 25, 19, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
    color: var(--ink);
    font-weight: 900;
  }

  .interactive-planner .planner-media {
    position: absolute;
    z-index: -1;
    top: -74px;
    right: calc(100% + clamp(18px, 3vw, 54px));
    display: flex;
    align-items: end;
    width: min(30vw, 300px);
    height: 120px;
    pointer-events: none;
    opacity: 0;
    transform: translateY(14px) rotate(-2deg);
    transition:
      opacity 0.28s ease,
      transform 0.36s cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .interactive-planner .planner-media img {
    width: 33%;
    height: 90px;
    margin-left: -26px;
    border-radius: 4px;
    object-fit: cover;
    box-shadow: 0 18px 34px rgba(7, 20, 17, 0.18);
  }

  .interactive-planner .planner-media img:nth-child(1) {
    transform: rotate(-10deg) translateY(14px);
  }

  .interactive-planner .planner-media img:nth-child(2) {
    transform: rotate(5deg) translateY(-6px);
  }

  .interactive-planner .planner-media img:nth-child(3) {
    transform: rotate(12deg) translateY(18px);
  }

  .interactive-planner .planner-field:hover .planner-media,
  .interactive-planner .planner-field:focus-within .planner-media {
    opacity: 0.72;
    transform: translateY(0) rotate(0deg);
  }

  .interactive-planner .planner-live-results {
    position: relative;
    z-index: 6;
    margin-top: 18px;
    border-radius: 18px;
    background: rgba(255, 253, 248, 0.94);
    box-shadow: 0 22px 58px rgba(7, 20, 17, 0.12);
  }

  .interactive-planner [data-planner-submit] {
    position: relative;
    z-index: 6;
    margin-top: 14px;
  }

  .split {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .section-title {
    max-width: 720px;
    margin-bottom: 24px;
  }

  .section-title h2,
  .custom-hero h2 {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.08;
  }
/* 
  .hotels-section {
    background:
      radial-gradient(
        circle at 85% 5%,
        rgba(243, 178, 58, 0.14),
        transparent 18rem
      ),
      linear-gradient(180deg, #fffdf8 0%, #f7efe1 100%);
  } */

  .hotel-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 24px;
  }

  .hotel-head h2 {
    max-width: 720px;
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.08;
  }

  .hotel-controls {
    display: flex;
    gap: 10px;
  }

  .hotel-controls button {
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: #fff;
    color: var(--ink);
    font: inherit;
    font-weight: 900;
    cursor: pointer;
  }

  .hotel-carousel {
    position: relative;
  }

  .hotel-track {
    position: relative;
    min-height: 500px;
  }

  .hotel-slide {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    overflow: hidden;
    border: 1px solid rgba(232, 221, 201, 0.9);
    border-radius: 34px;
    background: var(--surface-strong);
    box-shadow: 0 34px 100px rgba(23, 33, 27, 0.16);
    opacity: 0;
    pointer-events: none;
    transform: translateX(18px) scale(0.985);
    transition:
      opacity 380ms ease,
      transform 520ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hotel-slide.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0) scale(1);
  }

  .hotel-gallery {
    position: relative;
    min-height: 420px;
    overflow: hidden;
    background: #071411;
  }

  .hotel-gallery img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.06);
    animation: hotelImageFade 12s infinite;
  }

  .hotel-gallery .image-2 {
    animation-delay: 4s;
  }

  .hotel-gallery .image-3 {
    animation-delay: 8s;
  }

  .hotel-body {
    display: grid;
    align-content: center;
    gap: 14px;
    padding: 42px;
    background:
      radial-gradient(
        circle at 100% 0%,
        rgba(246, 183, 60, 0.14),
        transparent 16rem
      ),
      var(--surface-strong);
  }

  .hotel-body span {
    display: inline-flex;
    width: fit-content;
    padding: 6px 10px;
    border-radius: 999px;
    background: #eef8f4;
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hotel-body h3 {
    margin: 0;
    font-family: var(--ff-head);
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .hotel-body p {
    margin: 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .hotel-meta {
    display: grid;
    gap: 4px;
    margin-top: 8px;
    padding: 16px;
    border-radius: 22px;
    background: #fff4ea;
  }

  .hotel-meta strong {
    color: var(--accent-dark);
    font-size: 1.55rem;
    line-height: 1;
  }

  .hotel-meta small {
    color: var(--muted);
    font-weight: 800;
  }

  .hotel-body a,
  .hotel-body em {
    color: var(--accent-dark);
    font-style: normal;
    font-weight: 900;
    text-decoration: none;
  }

  .hotel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 18px;
  }

  .hotel-dots button {
    width: 32px;
    height: 8px;
    border: 0;
    border-radius: 999px;
    background: rgba(20, 116, 91, 0.22);
    cursor: pointer;
    transition:
      width 180ms ease,
      background 180ms ease;
  }

  .hotel-dots button.active {
    width: 54px;
    background: var(--green);
  }

  @keyframes hotelImageFade {
    0% {
      opacity: 0;
      transform: scale(1.06);
    }
    8%,
    33% {
      opacity: 1;
      transform: scale(1);
    }
    42%,
    100% {
      opacity: 0;
      transform: scale(1.04);
    }
  }

  .custom-hero {
    padding: 74px 0;
    background:
      radial-gradient(
        circle at 82% 20%,
        rgba(243, 178, 58, 0.14),
        transparent 20rem
      ),
      linear-gradient(135deg, #071411, #123f37);
    color: #fff;
  }

  .custom-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
  }

  .custom-hero p:not(.eyebrow) {
    max-width: 760px;
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.08rem;
  }

  @media (max-width: 760px) {
    .hero-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .hero-actions .button,
    .ghost-button {
      width: 100%;
      min-height: 50px;
      border-radius: 14px;
    }

    .planner-band {
      padding: 42px 0;
      border-radius: 28px;
      margin-inline: 12px;
    }

    .trip-planner {
      grid-template-columns: 1fr;
      border-radius: 26px;
    }

    .planner-copy {
      min-height: auto;
      padding: 24px;
    }

    .planner-copy h2 {
      font-size: 1.35rem;
    }

    .planner-fields {
      grid-template-columns: 1fr;
      padding: 14px;
      gap: 10px;
    }

    .planner-field.wide {
      grid-column: auto;
    }

    .planner-field select,
    .trip-planner button {
      min-height: 52px;
      border-radius: 16px;
    }

    .client-month-tours .section-head {
      align-items: center;
      flex-direction: row;
    }

    .client-month-tours .tour-grid {
      grid-template-columns: 1fr;
    }

    :global(.month-tour-card) {
      border-radius: 14px;
      box-shadow: 0 14px 40px rgba(23, 33, 27, 0.12);
      min-height: 520px;
    }

    :global(.month-image-link img) {
      height: 100%;
    }

    .split {
      align-items: flex-start;
      flex-direction: column;
    }

    .hotel-slide,
    .custom-grid {
      grid-template-columns: 1fr;
    }

    .hotel-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hotel-controls {
      width: 100%;
    }

    .hotel-controls button {
      flex: 1;
    }

    .hotel-slide {
      position: relative;
      inset: auto;
      border-radius: 26px;
    }

    .hotel-slide:not(.active) {
      display: none;
    }

    .hotel-track {
      min-height: 0;
    }

    .hotel-gallery {
      min-height: 300px;
    }

    .hotel-body {
      padding: 24px;
    }

    .custom-hero {
      margin-inline: 12px;
      border-radius: 28px;
      padding: 44px 0;
    }
  }

  /* Scroll-gallery home hero */
  .travel-hero {
    --progress: 0;
    --mask-progress: 0;
    --ui-opacity: 1;
    --gap: clamp(14px, 1.15vw, 22px);
    --mask-radius: 18px;
    --center-width: min(24vw, 370px);
    --center-left: calc((100vw - var(--center-width)) / 2);
    --center-right: calc((100vw - var(--center-width)) / 2);
    position: relative;
    min-height: calc(285svh - 20px);
    /* background:
      radial-gradient(
        circle at 12% 14%,
        rgba(243, 178, 58, 0.18),
        transparent 24rem
      ),
      radial-gradient(
        circle at 92% 8%,
        rgba(13, 117, 111, 0.16),
        transparent 26rem
      ),
      var(--bg); */
    color: #fff;
    margin: 10px;
    border-radius: 0.65rem;
    overflow: clip;
  }

  .travel-hero__sticky {
    position: sticky;
    top: 10px;
    height: calc(100svh - 20px);
    overflow: hidden;
    border-radius: inherit;
    /* background:
      radial-gradient(
        circle at 12% 14%,
        rgba(243, 178, 58, 0.14),
        transparent 24rem
      ),
      radial-gradient(
        circle at 92% 8%,
        rgba(13, 117, 111, 0.14),
        transparent 26rem
      ),
      var(--bg); */
  }

  .travel-hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    overflow: hidden;
    border-radius: calc(var(--mask-progress) * var(--mask-radius));
    clip-path: inset(
      calc(var(--mask-progress) * 18px)
        calc(var(--mask-progress) * var(--center-right))
        calc(var(--mask-progress) * 18px)
        calc(var(--mask-progress) * var(--center-left)) round
        calc(var(--mask-progress) * var(--mask-radius))
    );
  }

  .travel-hero__mask::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      radial-gradient(
        circle at 82% 68%,
        rgba(243, 178, 58, 0.16),
        transparent 24rem
      ),
      linear-gradient(
        90deg,
        rgba(7, 20, 17, 0.22),
        rgba(7, 20, 17, 0.04) 46%,
        rgba(7, 20, 17, 0.34)
      ),
      linear-gradient(180deg, rgba(7, 20, 17, 0.02), rgba(7, 20, 17, 0.28));
    opacity: calc(0.88 - var(--mask-progress) * 0.22);
    pointer-events: none;
  }

  .travel-hero__mask img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: calc(50% - var(--mask-progress) * 21%) center;
    transform: translateX(calc(var(--mask-progress) * 14%))
      scale(calc(1.04 - var(--mask-progress) * 0.02));
    filter: saturate(1.04) contrast(1.02);
  }

  .travel-hero__gallery {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .travel-hero__sticky > .container {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: grid;
    align-items: end;
    justify-items: end;
    padding-bottom: clamp(2rem, 9vh, 4rem);
  }

  :global(.travel-card) {
    --image-progress: 0;
    --from-x: 0px;
    --from-y: 0px;
    position: absolute;
    display: block;
    overflow: hidden;
    border-radius: 14px;
    background: #071411;
    color: #fff;
    text-decoration: none;
    box-shadow: none;
    opacity: var(--image-progress);
    transform: translate3d(
        calc(var(--from-x) * (1 - var(--image-progress))),
        calc(var(--from-y) * (1 - var(--image-progress))),
        0
      )
      scale(calc(0.985 + var(--image-progress) * 0.015));
  }

  :global(.travel-card img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    filter: saturate(1.04) contrast(1.02);
  }

  :global(.travel-card::after) {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(180deg, transparent 35%, rgba(7, 20, 17, 0.64)),
      linear-gradient(90deg, rgba(7, 20, 17, 0.2), transparent 64%);
    opacity: 0.7;
    pointer-events: none;
  }

  :global(.travel-card span) {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 10px;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 10px;
  }

  :global(.travel-card b) {
    color: var(--sun);
    font-size: clamp(0.68rem, 0.82vw, 0.82rem);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  :global(.travel-card small) {
    padding: 5px 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.58rem, 0.68vw, 0.68rem);
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.travel-card em) {
    position: absolute;
    left: 12px;
    top: 12px;
    z-index: 1;
    max-width: calc(100% - 24px);
    padding: 6px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.58rem, 0.68vw, 0.7rem);
    font-style: normal;
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    backdrop-filter: blur(10px);
  }

  :global(.card-mountain) {
    left: max(3vw, calc(var(--center-left) - 34vw - var(--gap)));
    top: 6svh;
    width: min(32vw, calc(var(--center-left) - 5vw - var(--gap)));
    height: 30svh;
    --from-x: -30vw;
    --from-y: -16svh;
  }

  :global(.card-temple) {
    left: max(10vw, calc(var(--center-left) - 26vw - var(--gap)));
    top: 40svh;
    width: min(25vw, calc(var(--center-left) - 12vw - var(--gap)));
    height: 30svh;
    --from-x: -22vw;
    --from-y: 18svh;
  }

  :global(.card-nature) {
    left: max(16vw, calc(var(--center-left) - 21vw - var(--gap)));
    top: 73svh;
    width: min(21vw, calc(var(--center-left) - 18vw - var(--gap)));
    height: 20svh;
    --from-x: -18vw;
    --from-y: 24svh;
  }

  :global(.card-backwater) {
    left: auto;
    right: max(11vw, calc(var(--center-right) - 25vw - var(--gap)));
    top: 15svh;
    width: min(24vw, calc(var(--center-right) - 12vw - var(--gap)));
    height: 25svh;
    --from-x: 24vw;
    --from-y: -18svh;
  }

  :global(.card-sea) {
    left: auto;
    right: max(3vw, calc(var(--center-right) - 34vw - var(--gap)));
    top: 44svh;
    width: min(32vw, calc(var(--center-right) - 5vw - var(--gap)));
    height: 28svh;
    --from-x: 26vw;
    --from-y: 10svh;
  }

  :global(.card-peak) {
    left: auto;
    right: max(17vw, calc(var(--center-right) - 22vw - var(--gap)));
    top: 78svh;
    width: min(21vw, calc(var(--center-right) - 18vw - var(--gap)));
    height: 18svh;
    --from-x: 18vw;
    --from-y: 22svh;
  }

  .travel-hero__content {
    transform: translateY(calc((1 - var(--ui-opacity)) * -28px));
    opacity: var(--ui-opacity);
    width: min(100%, 600px);
    margin-left: auto;
  }

  .travel-hero__content h1 {
    text-wrap: balance;
    margin: 0 0 20px;
    color: #fff;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.84;
    text-align: left;
    text-shadow: 0 18px 64px rgba(0, 0, 0, 0.26);
  }

  .travel-hero__content p:not(.eyebrow) {
    margin: 0 0 28px;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.05rem, 1.7vw, 1.35rem);
  }
  .travel-hero__content .button,
  .travel-hero__content .ghost-button {
    width: auto;
    min-height: 54px;
    padding-inline: 24px;
    border-radius: 999px;
  }

  .travel-hero__month-copy {
    position: absolute;
    z-index: 4;
    left: 50%;
    top: 58svh;
    color: var(--sun);
    font-family: var(--ff-head);
    max-width: min(52vw, 880px);
    font-size: clamp(40px, 4.5vw, 66px);
    font-weight: 900;
    line-height: 0.95;
    white-space: normal;
    opacity: var(--image-progress, 0);
    transform: translateX(-50%)
      translateY(calc((1 - var(--image-progress, 0)) * 34px));
    text-align: center;
  }

  .travel-hero__address {
    position: absolute;
    z-index: 4;
    left: auto;
    right: calc(var(--center-right) - 24vw);
    top: 61svh;
    max-width: 220px;
    margin: 0;
    color: rgba(23, 25, 19, 0.72);
    font-size: 1.05rem;
    font-weight: 900;
    line-height: 1.15;
    opacity: var(--image-progress, 0);
    transform: translateY(calc((1 - var(--image-progress, 0)) * 28px));
  }

  .travel-hero__address b {
    font-size: 1.65rem;
  }

  .travel-hero__address span {
    display: block;
    color: rgba(23, 25, 19, 0.45);
    font-weight: 800;
  }

  .brand-reveal {
    position: relative;
    z-index: 5;
    overflow: hidden;
    margin: 0;
    padding: clamp(64px, 8vw, 108px) 0 clamp(28px, 4vw, 52px);
    background: transparent;
    color: var(--ink);
  }

  .brand-reveal__inner {
    width: min(100% - 40px, 1180px);
    margin: 0 auto;
    text-align: center;
  }

  .brand-reveal .eyebrow {
    margin-bottom: 22px;
  }

  .brand-reveal__copy {
    max-width: 1100px;
    margin-inline: auto;
    font-family: inherit;
    font-size: clamp(1.5rem, 4vw, 4.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
    text-wrap: balance;
  }

  :global(.brand-word) {
    position: relative;
    display: inline-block;
    margin: 0 0.12em 0.16em 0;
    color: transparent;
    transform: translateY(10px);
    opacity: 1;
    transition:
      color 0.18s ease,
      opacity 0.42s ease,
      transform 0.42s cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  :global(.brand-word::before) {
    position: absolute;
    inset: 0.13em -0.02em 0.08em;
    content: "";
    border-radius: 999px;
    background: rgba(10, 20, 17, 0.12);
    transform-origin: left center;
    transition:
      opacity 0.34s ease,
      transform 0.46s cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  :global(.brand-word.is-visible) {
    color: var(--ink);
    /* transform: translateY(0); */
    opacity: 1;
  }

  :global(.brand-word.is-visible:nth-child(1)),
  :global(.brand-word.is-visible:nth-child(7)),
  :global(.brand-word.is-visible:nth-child(13)) {
    color: var(--sun);
  }

  :global(.brand-word.is-visible::before) {
    opacity: 0;
    /* transform: scaleX(0.08); */
  }

  .brand-marquee {
    width: 100%;
    margin-top: clamp(46px, 8vw, 104px);
    white-space: nowrap;
    transform: translateX(-1.5vw);

    color: rgba(7, 20, 17, 0.62);
    font-weight: 800;
  }

  .concierge-copy strong {
    margin: 14px 0;
    color: var(--ink);
    font-size: 1.3rem;
  }

  .concierge-copy button {
    min-height: 54px;
    padding-inline: 20px;
  }

  .concierge-signals {
    gap: 10px;
    padding: clamp(16px, 2vw, 24px);
  }

  .clue-chip > button,
  .concierge-planner .clue-chip > button {
    display: grid;
    gap: 4px;
    width: 100%;
    min-height: 70px;
    padding: 12px 14px;
    border: 1px solid rgba(7, 20, 17, 0.12);
    border-radius: 999px;
    background: #fffdf8;
    box-shadow: none;
    text-align: left;
  }

  .concierge-photo,
  .route-map-photo,
  .mood-cards {
    position: relative;
    overflow: hidden;
    border-radius: 22px;
    background: #071411;
  }

  .concierge-photo {
    min-height: 500px;
  }

  .route-map-board {
    position: relative;
    display: grid;
    grid-template-columns: minmax(250px, 0.3fr) minmax(0, 0.42fr) minmax(250px, 0.28fr);
    gap: 18px;
    min-height: 520px;
    padding: clamp(14px, 1.6vw, 18px);
    overflow: hidden;
  }

  .route-map-copy {
    display: grid;
    align-content: center;
    padding: clamp(22px, 3vw, 38px);
  }

  .route-map-copy p:not(.variant-kicker) {
    color: rgba(7, 20, 17, 0.62);
    font-weight: 800;
  }

  .route-map-copy strong {
    margin-top: 14px;
    color: var(--ink);
    font-size: 1.4rem;
  }

  .route-line {
    position: relative;
    display: grid;
    align-content: center;
    gap: 18px;
    padding: 28px 0;
  }

  .route-line::before {
    position: absolute;
    top: 9%;
    bottom: 9%;
    left: 22px;
    width: 2px;
    background: linear-gradient(var(--accent), rgba(7, 20, 17, 0.16));
    content: "";
  }

  .route-stop {
    position: relative;
    padding-left: 46px;
  }

  .route-stop::before {
    position: absolute;
    left: 11px;
    top: 28px;
    z-index: 2;
    width: 22px;
    height: 22px;
    border: 5px solid #fffdf8;
    border-radius: 999px;
    background: var(--accent);
    content: "";
  }

  .route-stop > button,
  .route-map-planner .route-stop > button {
    display: grid;
    gap: 4px;
    width: 100%;
    min-height: 76px;
    padding: 12px 14px;
    border: 1px solid rgba(7, 20, 17, 0.12);
    border-radius: 16px;
    background: #fffdf8;
    box-shadow: none;
    text-align: left;
  }

  .route-map-photo {
    min-height: 484px;
  }

  .route-map-photo button {
    position: absolute;
    z-index: 5;
    left: 18px;
    right: 18px;
    bottom: 18px;
    min-height: 54px;
  }

  .route-map-photo::after,
  .mood-cards::after,
  .concierge-photo::after,
  .boarding-photo::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(180deg, transparent 42%, rgba(7, 20, 17, 0.46));
    content: "";
  }

  .mood-deck-board {
    display: grid;
    grid-template-columns: minmax(250px, 0.28fr) minmax(320px, 0.44fr) minmax(250px, 0.28fr);
    gap: 18px;
    padding: clamp(14px, 1.6vw, 18px);
    align-items: stretch;
  }

  .mood-deck-board > div:first-child {
    display: grid;
    align-content: center;
    padding: clamp(22px, 3vw, 38px);
  }

  .mood-deck-board > div:first-child p:not(.variant-kicker) {
    color: rgba(7, 20, 17, 0.62);
    font-weight: 800;
  }

  .mood-cards {
    min-height: 500px;
    transform: rotate(-1deg);
  }

  .mood-controls {
    display: grid;
    align-content: center;
    gap: 10px;
  }

  .mood-pill > button,
  .mood-deck-planner .mood-pill > button {
    display: grid;
    gap: 4px;
    width: 100%;
    min-height: 76px;
    padding: 12px 14px;
    border: 1px solid rgba(7, 20, 17, 0.12);
    border-radius: 18px;
    background: #fffdf8;
    box-shadow: none;
    text-align: left;
  }

  .mood-footer {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 18px 0;
  }

  .mood-footer strong {
    color: var(--ink);
    font-size: 1.25rem;
  }

  .mood-footer button {
    min-height: 54px;
    padding-inline: 24px;
  }

  @media (max-width: 980px) {
    .boarding-ticket,
    .concierge-board,
    .route-map-board,
    .mood-deck-board {
      grid-template-columns: 1fr;
    }

    .boarding-main::after {
      display: none;
    }

    .boarding-photo,
    .concierge-photo,
    .route-map-photo,
    .mood-cards {
      min-height: 340px;
    }

    .boarding-stub {
      text-align: left;
    }
  }

  @media (max-width: 760px) {
    .planner-variant {
      border-radius: 22px;
    }

    .boarding-ticket,
    .concierge-board,
    .route-map-board,
    .mood-deck-board {
      gap: 10px;
      padding: 10px;
    }

    .boarding-fields,
    .passport-stamps,
    .concierge-signals,
    .mood-controls {
      display: flex;
      gap: 9px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
    }

    .boarding-field,
    .clue-chip,
    .mood-pill {
      flex: 0 0 min(210px, 72vw);
      scroll-snap-align: start;
    }

    .boarding-field.wide {
      grid-column: auto;
    }

    .route-line {
      overflow-x: auto;
      grid-auto-flow: column;
      grid-auto-columns: min(210px, 72vw);
      align-content: initial;
      padding: 2px 0 8px;
    }

    .route-line::before,
    .route-stop::before {
      display: none;
    }

    .route-stop {
      padding-left: 0;
    }

    .mood-footer {
      display: grid;
      padding-inline: 0;
    }

    .mood-footer button {
      width: 100%;
    }
  }

  /* Fresh planner concepts: visually distinct interaction models, not dropdown rearrangements. */
  .fresh-planner-lab {
    display: grid;
    gap: clamp(24px, 4vw, 46px);
    margin-top: clamp(32px, 5vw, 56px);
  }

  .fresh-concept {
    overflow: hidden;
    border: 1px solid rgba(7, 20, 17, 0.12);
    border-radius: 28px;
    background: #fffdf8;
  }

  .fresh-concept h3 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(2.25rem, 5vw, 5.2rem);
    line-height: 0.9;
  }

  .fresh-concept p {
    color: rgba(7, 20, 17, 0.64);
    font-weight: 800;
  }

  .concept-duel {
    display: grid;
    grid-template-columns: minmax(280px, 0.46fr) minmax(0, 0.54fr);
    min-height: 540px;
  }

  .duel-status {
    display: grid;
    align-content: center;
    padding: clamp(28px, 4vw, 56px);
    background:
      linear-gradient(180deg, rgba(7, 20, 17, 0.64), rgba(7, 20, 17, 0.96)),
      url("https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1100&q=82");
    background-position: center;
    background-size: cover;
    color: #fff;
  }

  .duel-status h3,
  .duel-status p,
  .duel-status strong {
    color: #fff;
  }

  .duel-status strong {
    margin-top: 20px;
    font-size: 1.1rem;
  }

  .duel-meter {
    display: block;
    height: 14px;
    margin-top: 8px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
  }

  .duel-meter i {
    display: block;
    width: 62%;
    height: 100%;
    border-radius: inherit;
    background: var(--accent);
  }

  .duel-stage {
    display: grid;
    align-content: center;
    gap: 20px;
    padding: clamp(28px, 4vw, 56px);
  }

  .duel-stage h3 {
    max-width: 11em;
    font-size: clamp(2rem, 3.7vw, 3.7rem);
  }

  .duel-choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .duel-choices button {
    min-height: 170px;
    padding: 22px;
    border: 0;
    border-radius: 20px;
    background-position: center;
    background-size: cover;
    color: #fff;
    font-size: clamp(1.4rem, 2.3vw, 2.1rem);
    font-weight: 950;
    text-align: left;
    cursor: pointer;
    box-shadow: inset 0 -100px 86px rgba(7, 20, 17, 0.58);
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      filter 0.24s ease;
  }

  .duel-choices button:hover {
    transform: translateY(-3px) rotate(-1deg);
  }

  .duel-choices button.is-selected {
    box-shadow:
      inset 0 -100px 86px rgba(7, 20, 17, 0.32),
      0 0 0 5px rgba(255, 190, 47, 0.78);
    filter: saturate(1.08);
    transform: translateY(-6px) rotate(-1deg);
  }

  .choice-mountain {
    background-image:
      linear-gradient(180deg, transparent, rgba(7, 20, 17, 0.2)),
      url("https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?auto=format&fit=crop&w=900&q=82");
  }

  .choice-sea {
    background-image:
      linear-gradient(180deg, transparent, rgba(7, 20, 17, 0.2)),
      url("https://images.unsplash.com/photo-1512343879784-a960bf40e7f2?auto=format&fit=crop&w=900&q=82");
  }

  .duel-actions,
  .swipe-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .duel-actions button,
  .duel-actions a,
  .swipe-actions button {
    display: inline-flex;
    align-items: center;
    min-height: 50px;
    padding: 0 18px;
    border: 0;
    border-radius: 999px;
    font-weight: 950;
    text-decoration: none;
    cursor: pointer;
  }

  .duel-actions button,
  .swipe-actions button:first-child {
    background: var(--ink);
    color: #fff;
  }

  .duel-actions a,
  .swipe-actions button:last-child {
    background: var(--accent);
    color: #fff;
  }

  .concept-cover {
    display: grid;
    grid-template-columns: minmax(340px, 0.58fr) minmax(300px, 0.42fr);
    min-height: 640px;
    background: var(--ink);
  }

  .cover-photo {
    min-height: 640px;
    background-position: center;
    background-size: cover;
  }

  .cover-copy {
    display: grid;
    align-content: space-between;
    padding: clamp(30px, 4vw, 58px);
    background: var(--ink);
    color: #fff;
  }

  .cover-copy h3 {
    color: #fff;
    font-size: clamp(3.6rem, 7vw, 7.4rem);
  }

  .cover-copy p {
    color: rgba(255, 255, 255, 0.76);
  }

  .cover-copy strong {
    color: var(--sun);
    font-size: clamp(1.4rem, 2.2vw, 2rem);
  }

  .cover-tags,
  .map-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .cover-tags button,
  .map-filters button {
    min-height: 44px;
    padding: 0 16px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-weight: 950;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .cover-tags button:hover,
  .cover-tags button.is-selected,
  .map-filters button:hover,
  .map-filters button.is-selected {
    border-color: transparent;
    background: var(--accent);
    color: #fff;
    transform: translateY(-2px);
  }

  .concept-swipe {
    display: grid;
    grid-template-columns: minmax(260px, 0.34fr) minmax(0, 0.66fr);
    gap: 24px;
    min-height: 610px;
    padding: clamp(26px, 3vw, 42px);
    background:
      radial-gradient(circle at 84% 18%, rgba(255, 190, 47, 0.24), transparent 21rem),
      #eef8f4;
  }

  .swipe-copy {
    display: grid;
    align-content: center;
  }

  .swipe-cards {
    position: relative;
    min-height: 520px;
  }

  .swipe-cards article {
    position: absolute;
    bottom: 18px;
    width: min(350px, 42%);
    height: 470px;
    display: grid;
    align-content: end;
    padding: 24px;
    overflow: hidden;
    border-radius: 24px;
    background-position: center;
    background-size: cover;
    color: #fff;
    box-shadow: 0 28px 70px rgba(7, 20, 17, 0.18);
    opacity: 0.72;
    filter: saturate(0.78);
    transition:
      transform 0.32s ease,
      opacity 0.32s ease,
      filter 0.32s ease;
  }

  .swipe-cards article.is-active {
    z-index: 6;
    opacity: 1;
    filter: none;
    transform: translateY(-14px) rotate(-1deg);
  }

  .swipe-cards article::before {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 38%, rgba(7, 20, 17, 0.72));
    content: "";
  }

  .swipe-cards article > * {
    position: relative;
    z-index: 2;
  }

  .swipe-cards article:nth-child(1) {
    left: 0;
    z-index: 4;
    background-image: url("https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?auto=format&fit=crop&w=900&q=82");
  }

  .swipe-cards article:nth-child(2) {
    left: 28%;
    z-index: 3;
    transform: rotate(4deg);
    background-image: url("https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?auto=format&fit=crop&w=900&q=82");
  }

  .swipe-cards article:nth-child(3) {
    right: 0;
    z-index: 2;
    transform: rotate(-3deg);
    background-image: url("https://images.unsplash.com/photo-1599661046289-e31897846e41?auto=format&fit=crop&w=900&q=82");
  }

  .swipe-cards span {
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .swipe-cards h4 {
    margin: 8px 0 0;
    color: #fff;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 0.94;
  }

  .concept-map {
    display: grid;
    grid-template-columns: minmax(300px, 0.42fr) minmax(0, 0.58fr);
    min-height: 620px;
  }

  .map-copy {
    display: grid;
    align-content: center;
    padding: clamp(30px, 4vw, 58px);
  }

  .map-copy strong {
    color: var(--ink);
    font-size: 1.2rem;
  }

  .map-filters button {
    border-color: rgba(7, 20, 17, 0.14);
    background: #fff;
    color: var(--ink);
  }

  .map-filters button:first-child {
    background: var(--ink);
    color: #fff;
  }

  .map-canvas {
    position: relative;
    min-height: 620px;
    overflow: hidden;
    background:
      radial-gradient(circle at 42% 52%, rgba(255, 190, 47, 0.28), transparent 17rem),
      radial-gradient(circle at 80% 30%, rgba(239, 111, 47, 0.12), transparent 17rem),
      #eef8f4;
  }

  .map-line {
    position: absolute;
    left: 16%;
    right: 12%;
    top: 55%;
    height: 3px;
    background: var(--accent);
    transform: rotate(-8deg);
  }

  .map-pin {
    position: absolute;
    width: clamp(112px, 11vw, 150px);
    height: clamp(112px, 11vw, 150px);
    display: grid;
    place-items: end center;
    padding: 16px;
    border: 8px solid #fffdf8;
    border-radius: 999px;
    background-position: center;
    background-size: cover;
    color: #fff;
    font-weight: 950;
    box-shadow: 0 18px 50px rgba(7, 20, 17, 0.16);
    cursor: pointer;
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      filter 0.28s ease;
  }

  .map-pin:hover,
  .map-pin.is-selected {
    border-color: var(--sun);
    filter: saturate(1.08);
    transform: translateY(-8px) scale(1.05);
  }

  .map-pin::before {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, transparent 26%, rgba(7, 20, 17, 0.62));
    content: "";
  }

  .map-pin {
    isolation: isolate;
  }

  .pin-sikkim {
    left: 14%;
    top: 20%;
    background-image: url("https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?auto=format&fit=crop&w=500&q=82");
  }

  .pin-goa {
    left: 43%;
    top: 48%;
    background-image: url("https://images.unsplash.com/photo-1512343879784-a960bf40e7f2?auto=format&fit=crop&w=500&q=82");
  }

  .pin-kerala {
    right: 15%;
    top: 28%;
    background-image: url("https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?auto=format&fit=crop&w=500&q=82");
  }

  @media (max-width: 900px) {
    .concept-duel,
    .concept-cover,
    .concept-swipe,
    .concept-map {
      grid-template-columns: 1fr;
    }

    .duel-status,
    .duel-stage,
    .cover-copy,
    .swipe-copy,
    .map-copy {
      padding: 26px;
    }

    .cover-photo,
    .map-canvas {
      min-height: 390px;
    }

    .concept-cover .cover-photo {
      order: -1;
    }

    .swipe-cards {
      min-height: 430px;
      overflow-x: auto;
    }

    .swipe-cards article {
      width: 260px;
      height: 360px;
    }
  }

  @media (max-width: 760px) {
    .fresh-concept {
      border-radius: 22px;
    }

    .duel-choices {
      grid-template-columns: 1fr;
    }

    .duel-choices button {
      min-height: 140px;
    }

    .cover-copy h3 {
      font-size: clamp(3rem, 16vw, 5rem);
    }

    .concept-swipe {
      padding: 20px;
    }

    .swipe-cards {
      margin-inline: -20px;
      padding-inline: 20px;
      scroll-snap-type: x proximity;
    }

    .swipe-cards article {
      position: relative;
      display: inline-grid;
      left: auto !important;
      right: auto !important;
      bottom: auto;
      margin-right: 12px;
      transform: none !important;
      scroll-snap-align: start;
    }

    .map-pin {
      width: 112px;
      height: 112px;
      border-width: 6px;
    }
  }

  /* Live planner reset: keep one understandable interactive planner on the page. */
  .route-passport-planner,
  .planner-variant,
  .fresh-planner-lab {
    display: none;
  }

  .planner-band {
    padding-block: clamp(56px, 8vw, 104px);
  }

  .interactive-planner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(18px, 3vw, 34px);
    padding: clamp(18px, 2.5vw, 30px);
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 28px;
    background:
      radial-gradient(circle at 85% 20%, rgba(255, 190, 47, 0.2), transparent 18rem),
      linear-gradient(135deg, #fffdf8, #eef8f4);
    box-shadow: none;
  }

  .interactive-planner .planner-copy {
    grid-column: 1 / -1;
    max-width: 720px;
    padding: 0;
  }

  .interactive-planner .planner-copy h2 {
    max-width: 660px;
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 4.2rem);
    line-height: 0.95;
  }

  .interactive-planner .planner-fields {
    grid-column: 1 / -1;
    min-width: 0;
  }

  .interactive-planner .planner-copy p:not(.eyebrow) {
    max-width: 620px;
    margin-top: 14px;
    color: rgba(7, 20, 17, 0.66);
    font-size: clamp(1rem, 1.4vw, 1.18rem);
    font-weight: 750;
    line-height: 1.55;
  }

  .sentence-planner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.6fr) minmax(300px, 0.4fr);
    gap: clamp(18px, 3vw, 34px);
    align-items: stretch;
    padding: clamp(16px, 2vw, 22px);
    overflow: visible;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 24px;
    background: rgba(255, 253, 248, 0.78);
  }

  .sentence-planner__copy {
    display: grid;
    align-content: center;
    gap: 18px;
    min-width: 0;
    padding: clamp(12px, 2vw, 28px);
  }

  .sentence-planner__kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .travel-sentence {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 9px 11px;
    max-width: 760px;
    color: var(--ink);
    font-size: clamp(1.35rem, 2.25vw, 2.28rem);
    font-weight: 920;
    line-height: 1.2;
  }

  .travel-sentence > span:not(.signal) {
    color: rgba(7, 20, 17, 0.76);
  }

  .interactive-planner .signal {
    position: relative;
    display: inline-flex;
    z-index: 10;
  }

  .interactive-planner .signal.is-open {
    z-index: 1000;
  }

  .interactive-planner .signal > button {
    position: relative;

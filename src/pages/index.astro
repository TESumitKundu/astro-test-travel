---
import BaseLayout from "../layouts/BaseLayout.astro";
import TourSection from "../components/TourSection.astro";
import {
  getAllMonths,
  getAllPlaces,
  getAllSeasons,
  getAllTravelStyles,
  getCurrentMonthName,
  formatInr,
  getLongDurationTours,
  getShortDurationTours,
} from "../lib/tours";
import { getFeaturedHotels } from "../lib/hotels";
import site from "../../config/site.json";
import { withBase } from "../lib/paths";

const currentMonth = getCurrentMonthName();
const shortTours = await getShortDurationTours(8);
const longTours = await getLongDurationTours(8);
const places = await getAllPlaces();
const seasons = await getAllSeasons();
const travelStyles = await getAllTravelStyles();
const months = getAllMonths();
const hotels = await getFeaturedHotels();
const hasMultipleHotels = hotels.length > 1;
const heroMoodTiles = site.heroMoodTiles || [];
---

<BaseLayout title={site.siteName} description={site.siteDescription}>
  <section class="travel-hero" data-travel-hero>
    <div class="travel-hero__sticky">
      <div class="travel-hero__gallery" data-travel-gallery></div>
      <script
        type="application/json"
        data-hero-mood-tiles
        set:html={JSON.stringify(heroMoodTiles)}
      />

      <div class="travel-hero__mask">
        <img
          src={withBase("/hero.jpg")}
          alt="A scenic India travel landscape"
        />
      </div>

      <div class="container">
        <div class="travel-hero__content">
        <p class="eyebrow">TOUR N MORE</p>
        <h1>Your perfect tour starts with the right guide.</h1>
        <!-- Your trusted guide to the perfect tour. -->
        <p>
          Month-smart routes, handpicked stays, and private plans shaped around
          weather, pace, and the way your group likes to travel.
        </p>
        <div class="hero-actions">
          <a class="button" href={withBase("/tours/")}>Explore tours</a>
          <a class="ghost-button" href="#plan-trip">Plan my trip</a>
        </div>
        </div>
      </div>

      <div class="travel-hero__month-copy" data-travel-copy>
        Choose your travel style
      </div>
    </div>
  </section>

  <section class="brand-reveal" data-brand-reveal>
    <div class="brand-reveal__inner">
      <p class="eyebrow">TrailNest Tours</p>
      <h4
        class="brand-reveal__copy"
      >
        We design India journeys around your month 🗓️, mood ✨, pace 🚶, and the
        places that stay with you long after the road ends 🧭
    </h4>
    </div>
    <div class="brand-marquee" aria-label="TOUR N MORE">
      <span>TOUR N MORE</span>
    </div>
  </section>

  <section class="section month-section">
    <div class="container">
      <section
        class="tour-section client-month-tours"
        data-month-tours
        data-tours-url={withBase("/data/tours.json")}
        data-base-path={withBase("/")}
      >
        <div class="section-head">
          <h2 data-month-title>{currentMonth} tours, ready to move</h2>
          <a
            data-month-view-all
            href={withBase(`/tours/?month=${currentMonth}`)}>View all</a
          >
        </div>
        <div class="tour-grid" data-month-results>
          <p class="month-loading">Finding this month&apos;s best trips...</p>
        </div>
      </section>
    </div>
    <script>
      type MonthTour = {
        title: string;
        slug: string;
        place: string;
        duration: { days: number; nights: number };
        bestMonths: string[];
        season?: string[];
        travelStyle?: string[];
        coverImage: string;
        costInr: number;
        minHeadCount: number;
      };

      type HeroMoodTile = {
        label: string;
        image: string;
        style: string;
        href: string;
        meta?: string;
      };

      const heroCardNames = [
        "card-mountain",
        "card-temple",
        "card-nature",
        "card-backwater",
        "card-sea",
        "card-peak",
      ];
      const heroCardLimit = heroCardNames.length;

      const monthNames = [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December",
      ];

      const escapeHtml = (value: string) =>
        value.replace(/[&<>"']/g, (character) => {
          const entities: Record<string, string> = {
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#039;",
          };
          return entities[character] || character;
        });

      const formatInrClient = (amount: number) =>
        new Intl.NumberFormat("en-IN", {
          style: "currency",
          currency: "INR",
          maximumFractionDigits: 0,
        }).format(amount);

      const formatDurationClient = (duration: MonthTour["duration"]) =>
        `${duration.nights} ${duration.nights === 1 ? "Night" : "Nights"} / ${duration.days} ${duration.days === 1 ? "Day" : "Days"}`;

      const getIndiaMonth = () =>
        new Intl.DateTimeFormat("en-US", {
          month: "long",
          timeZone: "Asia/Kolkata",
        }).format(new Date());

      const normalizeMonth = (month: string | null) => {
        if (!month) return getIndiaMonth();
        const match = monthNames.find(
          (monthName) => monthName.toLowerCase() === month.toLowerCase(),
        );
        return match || getIndiaMonth();
      };

      const withClientBase = (basePath: string, path: string) => {
        if (/^https?:\/\//.test(path)) return path;
        const cleanBase = basePath.endsWith("/")
          ? basePath.slice(0, -1)
          : basePath;
        return `${cleanBase}${path.startsWith("/") ? path : `/${path}`}`;
      };

      const renderMonthTour = (tour: MonthTour, basePath: string) => {
        const href = withClientBase(basePath, `/tours/${tour.slug}/`);
        const image = withClientBase(
          basePath,
          tour.coverImage || "/uploads/tour-kerala.svg",
        );

        return `
          <a class="month-tour-card" href="${href}" aria-label="${escapeHtml(tour.title)}">
            <span class="month-image-link">
              <img src="${image}" alt="" loading="lazy" />
            </span>
            <span class="month-card-body">
              <div class="month-place-row">
                <p class="month-place-heading">${escapeHtml(tour.place)}</p>
                <span>${escapeHtml(formatDurationClient(tour.duration))}</span>
              </div>
              <h3>${escapeHtml(tour.title)}</h3>
              <div class="month-price-row">
                <div>
                  <span>Starting from</span>
                  <br />
                  <strong>${formatInrClient(tour.costInr)}</strong>
                </div>
                <span>min ${tour.minHeadCount} heads</span>
              </div>
            </span>
          </a>
        `;
      };

      const renderHeroTourCard = (
        tour: MonthTour,
        basePath: string,
        index: number,
      ) => {
        const href = withClientBase(basePath, `/tours/${tour.slug}/`);
        const image = withClientBase(
          basePath,
          tour.coverImage || "/uploads/tour-kerala.svg",
        );
        return `
          <a class="travel-card ${heroCardNames[index] || "card-peak"}" href="${href}" data-travel-image aria-label="${escapeHtml(tour.title)}">
            <img src="${image}" alt="" loading="lazy" />
            <span>
              <b>${escapeHtml(tour.place)}</b>
              <small>${escapeHtml(formatDurationClient(tour.duration))}</small>
            </span>
          </a>
        `;
      };

      const getStyleFromTile = (tile: HeroMoodTile) => {
        if (tile.style) return tile.style;
        const href = tile.href || "";
        const style = new URLSearchParams(href.split("?")[1] || "").get(
          "style",
        );
        return style || tile.label;
      };

      const renderHeroStyleCard = (
        tile: HeroMoodTile,
        basePath: string,
        index: number,
        count: number,
      ) => {
        const style = getStyleFromTile(tile);
        const href = withClientBase(
          basePath,
          tile.href || `/tours/?style=${encodeURIComponent(style)}`,
        );
        const image = withClientBase(
          basePath,
          tile.image || "/uploads/tour-kerala.svg",
        );
        const countLabel = `${count} ${count === 1 ? "tour" : "tours"}`;

        return `
          <a class="travel-card mood-card ${heroCardNames[index] || "card-peak"}" href="${href}" data-travel-image aria-label="${escapeHtml(tile.label)}">
            <img src="${image}" alt="" loading="lazy" />
            <span>
              <b>${escapeHtml(tile.label)}</b>
              <small>${escapeHtml(countLabel)}</small>
            </span>
            <em>${escapeHtml(tile.meta || "Explore style")}</em>
          </a>
        `;
      };

      const monthSection =
        document.querySelector<HTMLElement>("[data-month-tours]");
      const heroGallery = document.querySelector<HTMLElement>(
        "[data-travel-gallery]",
      );
      const moodTilesData = document.querySelector<HTMLScriptElement>(
        "[data-hero-mood-tiles]",
      );
      const moodTiles: HeroMoodTile[] = moodTilesData?.textContent
        ? JSON.parse(moodTilesData.textContent)
        : [];

      if (monthSection) {
        const params = new URLSearchParams(window.location.search);
        const selectedMonth = normalizeMonth(params.get("month"));
        const toursUrl = monthSection.dataset.toursUrl || "/data/tours.json";
        const basePath = monthSection.dataset.basePath || "/";
        const title =
          monthSection.querySelector<HTMLElement>("[data-month-title]");
        const viewAll = monthSection.querySelector<HTMLAnchorElement>(
          "[data-month-view-all]",
        );
        const results = monthSection.querySelector<HTMLElement>(
          "[data-month-results]",
        );
        const heroMonth = document.querySelector<HTMLElement>(
          "[data-current-month-label]",
        );
        const heroCount = document.querySelector<HTMLElement>(
          "[data-current-month-count]",
        );

        title && (title.textContent = `Best Tours for ${selectedMonth}`);
        heroMonth && (heroMonth.textContent = selectedMonth);
        viewAll &&
          (viewAll.href = withClientBase(
            basePath,
            `/tours/?month=${encodeURIComponent(selectedMonth)}`,
          ));

        fetch(toursUrl)
          .then((response) => response.json() as Promise<MonthTour[]>)
          .then((tours) => {
            const monthTours = tours
              .filter(
                (tour) =>
                  Array.isArray(tour.bestMonths) &&
                  tour.bestMonths.includes(selectedMonth),
              )
              .sort((a, b) => a.costInr - b.costInr)
              .slice(0, 12);

            heroCount && (heroCount.textContent = String(monthTours.length));

            if (heroGallery) {
              const styleCards = moodTiles
                .slice(0, heroCardLimit)
                .map((tile, index) => {
                  const style = getStyleFromTile(tile);
                  const count = tours.filter(
                    (tour) =>
                      Array.isArray(tour.travelStyle) &&
                      tour.travelStyle.includes(style),
                  ).length;

                  return renderHeroStyleCard(tile, basePath, index, count);
                });

              heroGallery.innerHTML = styleCards.join("");
              window.dispatchEvent(
                new CustomEvent("travel-month-gallery-ready"),
              );
            }

            if (!results) return;

            results.innerHTML = monthTours.length
              ? monthTours
                  .map((tour) => renderMonthTour(tour, basePath))
                  .join("")
              : `<p class="month-loading">No tours are tagged for ${escapeHtml(selectedMonth)} yet.</p>`;
          })
          .catch(() => {
            heroCount && (heroCount.textContent = "0");
            if (results) {
              results.innerHTML =
                '<p class="month-loading">Tours could not be loaded right now.</p>';
            }
          });
      }
    </script>
    <script>
      const brandReveal = document.querySelector<HTMLElement>(
        "[data-brand-reveal]",
      );

      if (brandReveal) {
        const brandCopy =
          brandReveal.querySelector<HTMLElement>(".brand-reveal__copy");
        let brandWords: HTMLElement[] = [];

        if (brandCopy) {
          const copyText = brandCopy.textContent?.trim().replace(/\s+/g, " ");
          brandCopy.textContent = "";

          if (copyText) {
            copyText.split(/(\s+)/).forEach((part) => {
              if (!part.trim()) {
                brandCopy.append(document.createTextNode(part));
                return;
              }

              const word = document.createElement("span");
              word.className = "brand-word";
              word.textContent = part;
              brandCopy.append(word);
              brandWords.push(word);
            });
          }
        }

        brandWords = Array.from(
          brandReveal.querySelectorAll<HTMLElement>(".brand-word"),
        );
        let brandTicking = false;

        const updateBrandReveal = () => {
          const rect = brandReveal.getBoundingClientRect();
          const viewportHeight = window.innerHeight || 1;
          const progress = Math.min(
            Math.max(
              (viewportHeight * 0.64 - rect.top) / (rect.height * 0.58),
              0,
            ),
            1,
          );
          const visibleCount = Math.ceil(progress * brandWords.length);

          brandWords.forEach((word, index) => {
            word.classList.toggle("is-visible", index < visibleCount);
          });

          brandTicking = false;
        };

        const requestBrandReveal = () => {
          if (brandTicking) return;
          brandTicking = true;
          window.requestAnimationFrame(updateBrandReveal);
        };

        updateBrandReveal();
        window.addEventListener("scroll", requestBrandReveal, { passive: true });
        window.addEventListener("resize", requestBrandReveal);
      }
    </script>
  </section>

  <section class="planner-band" id="plan-trip">
    <div class="container">
      <form
        class="trip-planner interactive-planner planner-form1"
        action={withBase("/tours/")}
        method="get"
        data-trip-planner
        data-tours-url={withBase("/data/tours.json")}
        data-base-path={withBase("/")}
      >
        <div class="planner-copy">
          <p class="eyebrow">Plan your trip</p>
          <h2>Find tours that fit your mood.</h2>
          <p>
            Pick the signals that matter. Matching tours update instantly
            before you leave the page.
          </p>
        </div>
        <div class="planner-fields">
          <div class="planner-native-fields" aria-hidden="true">
            <select name="place" data-planner-filter>
              <option value="">Any place</option>
              {places.map((place) => <option value={place}>{place}</option>)}
            </select>
            <select name="duration" data-planner-filter>
              <option value="">Any length</option>
              <option value="short">Short escape</option>
              <option value="long">Long journey</option>
            </select>
            <select name="month" data-planner-filter>
              <option value="">Any month</option>
              {months.map((month) => <option value={month}>{month}</option>)}
            </select>
            <select name="season" data-planner-filter>
              <option value="">Any season</option>
              {
                seasons.map((season) => (
                  <option value={season}>{season}</option>
                ))
              }
            </select>
            <select name="style" data-planner-filter>
              <option value="">Any style</option>
              {
                travelStyles.map((style) => (
                  <option value={style}>{style}</option>
                ))
              }
            </select>
          </div>

          <div class="sentence-planner" data-sentence-planner>
            <div class="sentence-planner__copy">
              <p class="sentence-planner__kicker">Shape the trip</p>
              <div class="travel-sentence" aria-label="Trip search sentence">
                <span>I want to go to</span>
                <span class="signal" data-signal data-field="place">
                  <button type="button" data-signal-toggle aria-expanded="false">
                    <strong data-lane-value="place">Anywhere</strong>
                  </button>
                  <span class="signal-options">
                    <button type="button" data-planner-choice data-field="place" data-value="">Anywhere</button>
                    {places.map((place) => (
                      <button type="button" data-planner-choice data-field="place" data-value={place}>{place}</button>
                    ))}
                  </span>
                </span>
                <span>for</span>
                <span class="signal" data-signal data-field="duration">
                  <button type="button" data-signal-toggle aria-expanded="false">
                    <strong data-lane-value="duration">Any length</strong>
                  </button>
                  <span class="signal-options">
                    <button type="button" data-planner-choice data-field="duration" data-value="">Any length</button>
                    <button type="button" data-planner-choice data-field="duration" data-value="short">Short escape</button>
                    <button type="button" data-planner-choice data-field="duration" data-value="long">Long journey</button>
                  </span>
                </span>
                <span>in</span>
                <span class="signal" data-signal data-field="month">
                  <button type="button" data-signal-toggle aria-expanded="false">
                    <strong data-lane-value="month">Any month</strong>
                  </button>
                  <span class="signal-options">
                    <button type="button" data-planner-choice data-field="month" data-value="">Any month</button>
                    {months.map((month) => (
                      <button type="button" data-planner-choice data-field="month" data-value={month}>{month}</button>
                    ))}
                  </span>
                </span>
                <span>during</span>
                <span class="signal" data-signal data-field="season">
                  <button type="button" data-signal-toggle aria-expanded="false">
                    <strong data-lane-value="season">Any season</strong>
                  </button>
                  <span class="signal-options">
                    <button type="button" data-planner-choice data-field="season" data-value="">Any season</button>
                    {seasons.map((season) => (
                      <button type="button" data-planner-choice data-field="season" data-value={season}>{season}</button>
                    ))}
                  </span>
                </span>
                <span>with</span>
                <span class="signal" data-signal data-field="style">
                  <button type="button" data-signal-toggle aria-expanded="false">
                    <strong data-lane-value="style">Any style</strong>
                  </button>
                  <span class="signal-options">
                    <button type="button" data-planner-choice data-field="style" data-value="">Any style</button>
                    {travelStyles.map((style) => (
                      <button type="button" data-planner-choice data-field="style" data-value={style}>{style}</button>
                    ))}
                  </span>
                </span>
                <span>in mind.</span>
              </div>
              <button class="planner-sentence-submit" type="submit" data-planner-submit>
                Search tours
              </button>
              <div class="planner-next-step" aria-live="polite">
                <span>Selected so far</span>
                <strong data-planner-summary>Choose a signal to begin.</strong>
                <small>Open any highlighted word, pick one option, then search matching tours.</small>
              </div>
            </div>
            <div class="planner-visual" aria-hidden="true" data-planner-visual>
              <img class="is-active" data-visual-field="place" src={withBase("/hero.jpg")} alt="" />
              <img data-visual-field="duration" src="https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=900&q=82" alt="" />
              <img data-visual-field="month" src="https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=900&q=82" alt="" />
              <img data-visual-field="season" src="https://images.unsplash.com/photo-1433086966358-54859d0ed716?auto=format&fit=crop&w=900&q=82" alt="" />
              <img data-visual-field="style" src="https://images.unsplash.com/photo-1530789253388-582c481c54b0?auto=format&fit=crop&w=900&q=82" alt="" />
              <div class="planner-visual__content">
                <p data-planner-count>Loading tours...</p>
                <span data-visual-caption>Pick any signal. The preview follows your route.</span>
              </div>
            </div>
            <div class="planner-live-results" data-planner-results aria-label="Matching tour preview"></div>
          </div>
        </div>
      </form>

      <form
        class="trip-planner route-passport-planner planner-form2"
        action={withBase("/tours/")}
        method="get"
        data-trip-planner
        data-tours-url={withBase("/data/tours.json")}
        data-base-path={withBase("/")}
      >
        <div class="planner-native-fields" aria-hidden="true">
          <select name="place" data-planner-filter>
            <option value="">Any place</option>
            {places.map((place) => <option value={place}>{place}</option>)}
          </select>
          <select name="duration" data-planner-filter>
            <option value="">Any length</option>
            <option value="short">Short escape</option>
            <option value="long">Long journey</option>
          </select>
          <select name="month" data-planner-filter>
            <option value="">Any month</option>
            {months.map((month) => <option value={month}>{month}</option>)}
          </select>
          <select name="season" data-planner-filter>
            <option value="">Any season</option>
            {seasons.map((season) => <option value={season}>{season}</option>)}
          </select>
          <select name="style" data-planner-filter>
            <option value="">Any style</option>
            {travelStyles.map((style) => <option value={style}>{style}</option>)}
          </select>
        </div>

        <div class="passport-visual" aria-hidden="true" data-planner-visual>
          <img class="is-active" data-visual-field="place" src={withBase("/hero.jpg")} alt="" />
          <img data-visual-field="duration" src="https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=900&q=82" alt="" />
          <img data-visual-field="month" src="https://images.unsplash.com/photo-1470252649378-9c29740c9fa8?auto=format&fit=crop&w=900&q=82" alt="" />
          <img data-visual-field="season" src="https://images.unsplash.com/photo-1433086966358-54859d0ed716?auto=format&fit=crop&w=900&q=82" alt="" />
          <img data-visual-field="style" src="https://images.unsplash.com/photo-1530789253388-582c481c54b0?auto=format&fit=crop&w=900&q=82" alt="" />
          <div class="passport-visual__content">
            <p data-planner-count>Loading tours...</p>
            <span data-visual-caption>Start anywhere. Let one signal shape the route.</span>
          </div>
        </div>

        <div class="passport-panel">
          <p class="passport-kicker">Form2 / Route Passport</p>
          <h3>Stamp your route.</h3>
          <p>
            Choose only what you know. Each stamp narrows the tours instantly.
          </p>

          <div class="passport-stamps">
            <span class="signal passport-stamp" data-signal data-field="place">
              <button type="button" data-signal-toggle aria-expanded="false">
                <span>Destination</span>
                <strong data-lane-value="place">Anywhere</strong>
              </button>
              <span class="signal-options passport-options">
                <button type="button" data-planner-choice data-field="place" data-value="">Anywhere</button>
                {places.map((place) => (
                  <button type="button" data-planner-choice data-field="place" data-value={place}>{place}</button>
                ))}
              </span>
            </span>

            <span class="signal passport-stamp" data-signal data-field="duration">
              <button type="button" data-signal-toggle aria-expanded="false">
                <span>Duration</span>
                <strong data-lane-value="duration">Any length</strong>
              </button>
              <span class="signal-options passport-options">
                <button type="button" data-planner-choice data-field="duration" data-value="">Any length</button>
                <button type="button" data-planner-choice data-field="duration" data-value="short">Short escape</button>
                <button type="button" data-planner-choice data-field="duration" data-value="long">Long journey</button>
              </span>
            </span>

            <span class="signal passport-stamp" data-signal data-field="month">
              <button type="button" data-signal-toggle aria-expanded="false">
                <span>Month</span>
                <strong data-lane-value="month">Any month</strong>
              </button>
              <span class="signal-options passport-options">
                <button type="button" data-planner-choice data-field="month" data-value="">Any month</button>
                {months.map((month) => (
                  <button type="button" data-planner-choice data-field="month" data-value={month}>{month}</button>
                ))}
              </span>
            </span>

            <span class="signal passport-stamp" data-signal data-field="season">
              <button type="button" data-signal-toggle aria-expanded="false">
                <span>Season</span>
                <strong data-lane-value="season">Any season</strong>
              </button>
              <span class="signal-options passport-options">

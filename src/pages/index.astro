    }

    .hotels-section {
      padding: 72px 0;
    }

    .hotel-gallery {
      min-height: 420px;
    }

    .custom-hero {
      min-height: 60svh;
      margin-inline: 0;
      border-radius: 0;
    }
  }

  .interactive-planner {
    overflow: visible;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .interactive-planner .planner-fields {
    grid-template-columns: 1fr;
    gap: 0;
    overflow: visible;
    padding: 0;
  }

  .interactive-planner .planner-field,
  .interactive-planner .planner-field.wide,
  .interactive-planner :global(label.planner-field) {
    position: relative;
    display: grid;
    grid-column: auto;
    grid-template-columns: minmax(180px, 0.58fr) minmax(180px, 0.42fr);
    align-items: center;
    min-height: 92px;
    margin: -1px 0 0;
    align-content: initial;
    padding: 18px 28px;
    overflow: visible;
    border: 0;
    border-radius: 0;
    border-right: 0;
    border-bottom: 0;
    background: #dedede;
    box-shadow: none;
    color: var(--ink);
    clip-path: polygon(0 0, calc(100% - 38px) 0, 100% 45%, 100% 100%, 0 100%);
  }

  .interactive-planner .planner-field:nth-of-type(odd),
  .interactive-planner :global(label.planner-field:nth-of-type(odd)) {
    background: #f2f2f0;
  }

  .interactive-planner .planner-field:nth-of-type(2),
  .interactive-planner :global(label.planner-field:nth-of-type(2)) {
    margin-left: clamp(22px, 4vw, 68px);
  }

  .interactive-planner .planner-field:nth-of-type(3),
  .interactive-planner :global(label.planner-field:nth-of-type(3)) {
    margin-right: clamp(28px, 8vw, 130px);
  }

  .interactive-planner .planner-field:nth-of-type(4),
  .interactive-planner :global(label.planner-field:nth-of-type(4)) {
    margin-left: clamp(58px, 10vw, 180px);
  }

  .interactive-planner .planner-field:nth-of-type(5),
  .interactive-planner :global(label.planner-field:nth-of-type(5)) {
    margin-right: clamp(14px, 5vw, 90px);
  }

  .interactive-planner [data-planner-submit],
  .interactive-planner :global(.planner-fields > button) {
    min-height: 58px;
    border-radius: 999px;
  }

  .interactive-planner .planner-live-results {
    grid-column: 1 / -1;
  }

  @media (max-width: 760px) {
    .interactive-planner .planner-fields {
      gap: 8px;
      padding: 0;
    }

    .interactive-planner .planner-field,
    .interactive-planner .planner-field.wide,
    .interactive-planner :global(label.planner-field) {
      grid-template-columns: minmax(0, 1fr);
      min-height: 118px;
      margin: 0;
      padding: 16px;
      border-radius: 18px;
      clip-path: none;
    }

    .interactive-planner .planner-title,
    .interactive-planner :global(label.planner-field > .planner-title) {
      font-size: clamp(1.65rem, 8vw, 2.6rem);
    }

    .interactive-planner .planner-field select,
    .interactive-planner :global(label.planner-field select) {
      grid-column: auto;
    }

    .interactive-planner .planner-field:hover,
    .interactive-planner .planner-field:focus-within,
    .interactive-planner :global(label.planner-field:hover),
    .interactive-planner :global(label.planner-field:focus-within) {
      transform: none;
    }

    .interactive-planner .planner-media {
      top: -20px;
      right: 12px;
      width: 150px;
      height: 70px;
      opacity: 0.18;
      transform: none;
    }

    .interactive-planner .planner-field:hover .planner-media,
    .interactive-planner .planner-field:focus-within .planner-media {
      opacity: 0.58;
    }

    .interactive-planner .planner-media img {
      height: 62px;
      margin-left: -28px;
    }

    .interactive-planner .planner-live-results,
    .interactive-planner .planner-preview-grid {
      grid-template-columns: 1fr;
    }

    .interactive-planner .planner-preview-grid {
      display: grid;
      max-height: 270px;
      overflow-y: auto;
    }

    :global(.planner-preview-card) {
      min-height: 132px;
    }
  }

  /* Final planner pass: compact travel console. This intentionally overrides the older strip experiment above. */
  .interactive-planner {
    grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
    overflow: hidden;
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.94), rgba(239, 248, 244, 0.9)),
      #fffdf8;
    box-shadow: 0 34px 100px rgba(7, 20, 17, 0.14);
  }

  .interactive-planner .planner-copy {
    min-height: 0;
    padding: clamp(28px, 4vw, 46px);
    border-radius: 28px 0 0 28px;
    background:
      linear-gradient(160deg, rgba(11, 51, 45, 0.94), rgba(7, 20, 17, 0.98)),
      #071411;
    box-shadow: none;
  }

  .interactive-planner .planner-copy h2 {
    max-width: 7.5em;
    font-size: clamp(2rem, 3.35vw, 3.35rem);
    line-height: 1;
  }

  .interactive-planner .planner-copy p:not(.eyebrow) {
    max-width: 34ch;
    font-size: 0.98rem;
  }

  .interactive-planner .planner-fields {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.38fr);
    gap: 14px;
    overflow: hidden;
    padding: clamp(14px, 2vw, 20px);
    border-radius: 0 28px 28px 0;
    background: transparent;
  }

  .interactive-planner .planner-native-fields {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .journey-board {
    display: grid;
    grid-column: 1 / -1;
    gap: 8px;
  }

  .journey-lane {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    transition:
      background 0.24s ease,
      border-color 0.24s ease,
      transform 0.24s ease;
  }

  .journey-lane::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    content: "";
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.24s ease;
  }

  .journey-lane:hover,
  .journey-lane.is-open {
    border-color: rgba(239, 111, 47, 0.34);
    background:
      linear-gradient(135deg, rgba(255, 244, 234, 0.94), rgba(238, 248, 244, 0.92)),
      #fffdf8;
    transform: translateY(-1px);
  }

  .journey-lane.is-open::before {
    opacity: 1;
  }

  .journey-lane__head {
    display: grid;
    grid-template-columns: minmax(120px, 0.36fr) minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    width: 100%;
    min-height: 68px;
    padding: 14px 18px 14px 22px;
    border: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .journey-lane__head span {
    color: rgba(7, 20, 17, 0.56);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .journey-lane__head strong {
    overflow: hidden;
    color: var(--ink);
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    font-weight: 950;
    line-height: 1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .journey-lane__head::after {
    justify-self: end;
    grid-column: 2;
    content: "+";
    width: 28px;
    height: 28px;
    margin-top: -28px;
    border-radius: 999px;
    background: rgba(7, 20, 17, 0.08);
    color: var(--ink);
    display: grid;
    place-items: center;
    font-weight: 900;
    transition: transform 0.24s ease;
  }

  .journey-lane.is-open .journey-lane__head::after {
    transform: rotate(45deg);
  }

  .journey-options {
    display: flex;
    gap: 8px;
    max-height: 0;
    padding: 0 16px;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.34s ease,
      padding 0.34s ease,
      opacity 0.2s ease;
  }

  .journey-lane.is-open .journey-options {
    max-height: 170px;
    padding: 0 16px 16px;
    overflow-x: auto;
    opacity: 1;
  }

  .journey-options button {
    flex: 0 0 auto;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--ink);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 850;
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .journey-options button:hover,
  .journey-options button.is-selected {
    background: var(--ink);
    color: #fff;
  }

  .journey-options button:active {
    transform: translateY(1px);
  }

  .interactive-planner .planner-live-results {
    grid-column: 1;
    display: grid;
    grid-template-columns: minmax(180px, 0.38fr) minmax(0, 0.62fr);
    gap: 14px;
    align-items: center;
    min-height: 116px;
    margin: 0;
    padding: 16px;
    border: 1px solid rgba(7, 20, 17, 0.08);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: none;
  }

  .interactive-planner [data-planner-submit],
  .interactive-planner :global(.planner-fields > button) {
    grid-column: 2;
    min-height: 116px;
    margin: 0;
    border-radius: 18px;
    box-shadow: none;
  }

  .interactive-planner [data-planner-submit]:active {
    transform: translateY(1px);
  }

  @media (max-width: 980px) {
    .interactive-planner {
      grid-template-columns: 1fr;
    }

    .interactive-planner .planner-copy {
      border-radius: 28px 28px 0 0;
    }

    .interactive-planner .planner-copy h2 {
      max-width: 12em;
    }

    .interactive-planner .planner-fields {
      grid-template-columns: 1fr;
      border-radius: 0 0 28px 28px;
    }

    .interactive-planner .planner-live-results,
    .interactive-planner [data-planner-submit],
    .interactive-planner :global(.planner-fields > button) {
      grid-column: 1;
    }
  }

  @media (max-width: 760px) {
    .interactive-planner {
      border-radius: 24px;
    }

    .interactive-planner .planner-fields {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 10px;
    }

    .journey-board {
      gap: 7px;
    }

    .journey-lane {
      border-radius: 16px;
    }

    .journey-lane__head {
      grid-template-columns: 1fr;
      gap: 8px;
      min-height: 76px;
      padding: 14px 16px;
    }

    .journey-lane__head strong {
      max-width: calc(100% - 38px);
      font-size: 1.28rem;
    }

    .journey-lane__head::after {
      position: absolute;
      top: 18px;
      right: 14px;
      margin: 0;
    }

    .journey-lane.is-open .journey-options {
      padding-inline: 14px;
      padding-bottom: 14px;
    }

    .interactive-planner .planner-live-results,
    .interactive-planner [data-planner-submit],
    .interactive-planner :global(.planner-fields > button) {
      grid-column: 1 / -1;
      min-height: 58px;
      border-radius: 999px;
    }

    .interactive-planner .planner-live-results {
      grid-template-columns: 1fr;
      border-radius: 16px;
    }
  }

  /* Sentence planner: final visual layer that matches the hero and text-reveal sections. */
  .planner-band {
    padding: clamp(72px, 10vw, 132px) 0;
  }

  .interactive-planner {
    position: relative;
    display: block;
    overflow: visible;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .interactive-planner .planner-copy {
    display: block;
    max-width: 860px;
    min-height: 0;
    padding: 0 0 clamp(26px, 4vw, 48px);
    border-radius: 0;
    background: transparent;
    color: var(--ink);
  }

  .interactive-planner .planner-copy .eyebrow {
    color: var(--accent);
  }

  .interactive-planner .planner-copy h2 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(2.45rem, 5.8vw, 5.7rem);
    line-height: 0.92;
    text-wrap: balance;
  }

  .interactive-planner .planner-copy p:not(.eyebrow) {
    max-width: 42ch;
    margin-top: 18px;
    color: rgba(7, 20, 17, 0.64);
    font-size: clamp(1rem, 1.35vw, 1.18rem);
  }

  .interactive-planner .planner-fields {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.32fr);
    gap: 18px;
    overflow: visible;
    padding: 0;
    border-radius: 0;
  }

  .sentence-planner {
    grid-column: 1 / -1;
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.68fr) minmax(280px, 0.32fr);
    gap: clamp(24px, 4vw, 56px);
    align-items: center;
    padding: clamp(26px, 4vw, 52px);
    overflow: visible;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 28px;
    background:
      radial-gradient(circle at 78% 16%, rgba(255, 190, 47, 0.28), transparent 24rem),
      radial-gradient(circle at 12% 100%, rgba(239, 111, 47, 0.14), transparent 22rem),
      linear-gradient(135deg, rgba(239, 248, 244, 0.98), rgba(255, 250, 238, 0.94));
  }

  .sentence-planner__copy {
    position: relative;
    z-index: 3;
  }

  .sentence-planner__kicker {
    margin: 0 0 16px;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .travel-sentence {
    max-width: 1160px;
    color: rgba(7, 20, 17, 0.9);
    font-family: var(--display-font);
    font-size: clamp(2rem, 4.15vw, 4.85rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .travel-sentence > span {
    display: inline;
  }

  .signal {
    position: relative;
    display: inline-block;
    margin: 0 0.06em 0.18em;
    vertical-align: baseline;
  }

  .signal > button {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    max-width: min(100%, 9.5em);
    padding: 0 0.12em 0.04em;
    border: 0;
    border-radius: 0.08em;
    background:
      linear-gradient(transparent 58%, rgba(255, 190, 47, 0.62) 58%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0));
    color: var(--ink);
    font: inherit;
    line-height: inherit;
    cursor: pointer;
    box-shadow: 0 10px 40px rgba(239, 111, 47, 0.08);
    transition:
      transform 0.22s ease,
      background 0.22s ease,
      color 0.22s ease;
  }

  .signal:hover > button,
  .signal.is-open > button {
    color: #071411;
    transform: translateY(-0.03em) rotate(-0.4deg);
    background:
      linear-gradient(transparent 48%, rgba(255, 190, 47, 0.86) 48%),
      rgba(255, 255, 255, 0.48);
  }

  .signal > button strong {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .signal > button::after {
    content: "";
    position: absolute;
    right: 0.02em;
    bottom: 0.08em;
    width: 0.18em;
    height: 0.18em;
    border-radius: 999px;
    background: var(--accent);
    transform: scale(0.8);
    transition: transform 0.2s ease;
  }

  .signal:hover > button::after,
  .signal.is-open > button::after {
    transform: scale(1.25);
  }

  .signal-options {
    position: absolute;
    z-index: 30;
    left: 50%;
    top: calc(100% + 12px);
    bottom: auto;
    display: none;
    gap: 8px;
    width: max-content;
    max-width: min(72vw, 680px);
    max-height: none;
    padding: 12px;
    overflow-x: auto;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, 0.96), rgba(239, 248, 244, 0.94)),
      rgba(255, 253, 248, 0.92);
    box-shadow: 0 24px 70px rgba(7, 20, 17, 0.16);
    opacity: 1;
    transform: translateX(-50%) translateY(8px) scale(0.98);
    backdrop-filter: blur(14px);
    transition:
      opacity 0.22s ease,
      transform 0.28s ease;
  }

  .signal.is-open {
    z-index: 35;
  }

  .signal.is-open .signal-options {
    display: flex;
    animation: signal-pop 0.24s cubic-bezier(0.2, 0.75, 0.25, 1) both;
  }

  .signal-options button {
    position: relative;
    flex: 0 0 auto;
    min-height: 48px;
    padding: 0 46px 0 16px;
    border: 1px solid rgba(7, 20, 17, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--ink);
    font-family: var(--body-font);
    font-size: 0.92rem;
    font-weight: 900;
    box-shadow: 0 18px 44px rgba(7, 20, 17, 0.1);
    cursor: pointer;
  }

  .signal-options button::after {
    position: absolute;
    top: 50%;
    right: 10px;
    min-width: 26px;
    padding: 4px 7px;
    border-radius: 999px;
    background: rgba(255, 190, 47, 0.28);
    color: var(--ink);
    content: attr(data-count);
    font-size: 0.72rem;
    font-weight: 950;
    line-height: 1;
    transform: translateY(-50%);
  }

  .signal-options button:hover,
  .signal-options button.is-selected {
    border-color: #071411;
    background: #071411;
    color: #fff;
  }

  .signal-options button:hover::after,
  .signal-options button.is-selected::after {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  @keyframes signal-pop {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(14px) scale(0.96);
    }

    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .planner-visual {
    position: relative;
    min-height: clamp(300px, 36vw, 520px);
    border-radius: 22px;
    overflow: hidden;
    background: #071411;
    box-shadow: 0 30px 80px rgba(7, 20, 17, 0.18);
    transform: rotate(1.5deg);
  }

  .planner-visual::before {
    position: absolute;
    inset: 14px;
    z-index: 4;
    content: "";
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 16px;
    pointer-events: none;
  }

  .planner-visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.08) rotate(-1deg);
    transition:
      opacity 0.34s ease,
      transform 0.7s cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .planner-visual img.is-active {
    opacity: 1;
    transform: scale(1.01) rotate(0deg);
  }

  .planner-visual img.is-active + img {
    transform: scale(1.06) rotate(1deg);
  }

  .planner-visual::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    content: "";
    background:
      linear-gradient(180deg, transparent 30%, rgba(7, 20, 17, 0.62)),
      linear-gradient(90deg, rgba(7, 20, 17, 0.18), transparent 62%);
  }

  .planner-visual span {
    position: absolute;
    z-index: 5;
    left: 24px;
    right: 24px;
    bottom: 22px;
    color: #fff;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    font-weight: 900;
    line-height: 1.05;
  }

  .planner-visual span::before {
    display: block;
    width: 44px;
    height: 5px;
    margin-bottom: 12px;
    border-radius: 999px;
    background: var(--sun);
    content: "";
  }

  .interactive-planner.has-signals .planner-live-results {
    border-color: rgba(239, 111, 47, 0.24);
    background: rgba(255, 244, 234, 0.72);
  }

  .interactive-planner .planner-live-results {
    grid-column: 1;
    display: grid;
    grid-template-columns: minmax(180px, 0.34fr) minmax(0, 0.66fr);
    gap: 16px;
    min-height: 118px;
    margin-top: 0;
    padding: 16px;
    border: 1px solid rgba(7, 20, 17, 0.1);
    border-radius: 18px;
    background: rgba(255, 253, 248, 0.78);
    box-shadow: none;
  }

  .interactive-planner [data-planner-submit],
  .interactive-planner :global(.planner-fields > button) {
    grid-column: 2;
    min-height: 118px;
    margin-top: 0;
    border-radius: 18px;
    box-shadow: none;
  }

  @media (max-width: 900px) {
    .interactive-planner .planner-fields {
      grid-template-columns: 1fr;
    }

    .sentence-planner {
      grid-template-columns: 1fr;
    }

    .planner-visual {
      min-height: 320px;
      transform: rotate(0deg);
    }

    .interactive-planner .planner-live-results,
    .interactive-planner [data-planner-submit],
    .interactive-planner :global(.planner-fields > button) {
      grid-column: 1;
    }
  }

  @media (max-width: 760px) {
    .planner-band {
      padding: 64px 0;
      background: transparent;
    }

    .interactive-planner .planner-copy {
      padding-bottom: 24px;
    }

    .interactive-planner .planner-copy h2 {
      font-size: clamp(2.45rem, 12vw, 4rem);
    }

    .travel-sentence {
      font-size: clamp(1.72rem, 8.6vw, 3rem);
      line-height: 1.15;
    }

    .signal {
      position: relative;

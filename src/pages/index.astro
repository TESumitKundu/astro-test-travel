          coverImage: string;
          costInr: number;
        };

        const tripPlanners = Array.from(
          document.querySelectorAll<HTMLFormElement>("[data-trip-planner]"),
        );

        tripPlanners.forEach((tripPlanner) => {
          const plannerBasePath = tripPlanner.dataset.basePath || "/";
          const plannerToursUrl =
            tripPlanner.dataset.toursUrl || "/data/tours.json";
          const filters = Array.from(
            tripPlanner.querySelectorAll<HTMLSelectElement>("[data-planner-filter]"),
          );
          const count = tripPlanner.querySelector<HTMLElement>("[data-planner-count]");
          const summary =
            tripPlanner.querySelector<HTMLElement>("[data-planner-summary]");
          const results =
            tripPlanner.querySelector<HTMLElement>("[data-planner-results]");
          const submit =
            tripPlanner.querySelector<HTMLButtonElement>("[data-planner-submit]");
          const signalToggles = Array.from(
            tripPlanner.querySelectorAll<HTMLButtonElement>("[data-signal-toggle]"),
          );
          const choiceButtons = Array.from(
            tripPlanner.querySelectorAll<HTMLButtonElement>("[data-planner-choice]"),
          );
          const laneValues = Array.from(
            tripPlanner.querySelectorAll<HTMLElement>("[data-lane-value]"),
          );
          const visualImages = Array.from(
            tripPlanner.querySelectorAll<HTMLImageElement>("[data-visual-field]"),
          );
          const visualCaption =
            tripPlanner.querySelector<HTMLElement>("[data-visual-caption]");
          let plannerTours: PlannerTour[] = [];

          const signalLabels: Record<string, string> = {
            place: "Choose a destination and the picture follows.",
            duration: "Set the pace. Quick dash or slow drift.",
            month: "Pick a month and let the weather do some work.",
            season: "Choose the season that feels right.",
            style: "Tune the mood of the journey.",
          };

          const placeImageMap: Record<string, string> = {
            Goa: "/uploads/tour-goa.svg",
            Kerala: "/uploads/tour-kerala.svg",
            Ladakh: "/uploads/tour-ladakh.svg",
            Meghalaya: "/uploads/tour-meghalaya.svg",
            Nepal: "/uploads/Tourist-Attractions-in-Kathmandu-Nepal-.jpg",
            Rajasthan: "/uploads/tour-rajasthan.svg",
            Sikkim: "/uploads/tour-sikkim.svg",
          };

          const getField = (name: string) =>
            tripPlanner.querySelector<HTMLSelectElement>(`select[name="${name}"]`);

          const plannerPath = (path: string) => {
            if (/^https?:\/\//.test(path)) return path;
            const cleanBase = plannerBasePath.endsWith("/")
              ? plannerBasePath.slice(0, -1)
              : plannerBasePath;
            return `${cleanBase}${path.startsWith("/") ? path : `/${path}`}`;
          };

          const defaultPlannerImage = plannerPath("/hero.jpg");

          const getPlannerState = () => ({
            place: getField("place")?.value || "",
            duration: getField("duration")?.value || "",
            month: getField("month")?.value || "",
            season: getField("season")?.value || "",
            style: getField("style")?.value || "",
          });

          const escapePlannerHtml = (value: string) =>
            value.replace(/[&<>"']/g, (character) => {
              const entities: Record<string, string> = {
                "&": "&amp;",
                "<": "&lt;",
                ">": "&gt;",
                '"': "&quot;",
                "'": "&#039;",
              };
              return entities[character] || character;
            });

          const tourMatches = (tour: PlannerTour) => {
            const state = getPlannerState();
            return matchesState(tour, state);
          };

          const matchesState = (
            tour: PlannerTour,
            state: ReturnType<typeof getPlannerState>,
          ) => {
            const isShort = tour.duration.days <= 4;
            return (
              (!state.place || tour.place === state.place) &&
              (!state.duration ||
                (state.duration === "short" ? isShort : !isShort)) &&
              (!state.month ||
                (Array.isArray(tour.bestMonths) &&
                  tour.bestMonths.includes(state.month))) &&
              (!state.season ||
                (Array.isArray(tour.season) && tour.season.includes(state.season))) &&
              (!state.style ||
                (Array.isArray(tour.travelStyle) &&
                  tour.travelStyle.includes(state.style)))
            );
          };

          const getCountForChoice = (field: string, value: string) => {
            const state = { ...getPlannerState(), [field]: value };
            return plannerTours.filter((tour) => matchesState(tour, state)).length;
          };

          const setVisualByField = (field: string, caption?: string) => {
            visualImages.forEach((image) => {
              image.classList.toggle("is-active", image.dataset.visualField === field);
            });
            if (visualCaption) {
              visualCaption.textContent = caption || signalLabels[field] || "Pick a signal.";
            }
          };

          const updatePlannerVisual = (activeField?: string) => {
            const state = getPlannerState();
            const placeImage = state.place && placeImageMap[state.place];
            const placeVisual = visualImages.find((image) => image.dataset.visualField === "place");
            if (placeImage) {
              if (placeVisual) placeVisual.src = plannerPath(placeImage);
              setVisualByField("place", `${state.place} is now on the map.`);
              return;
            }
            if (placeVisual) placeVisual.src = defaultPlannerImage;
            if (state.style) {
              setVisualByField("style", `${state.style} trips are in focus.`);
              return;
            }
            if (state.season) {
              setVisualByField("season", `${state.season} routes are warming up.`);
              return;
            }
            if (state.month) {
              setVisualByField("month", `${state.month} travel windows are ready.`);
              return;
            }
            if (state.duration) {
              setVisualByField("duration", "The trip pace is set.");
              return;
            }
            setVisualByField(activeField || "place");
          };

          const renderPlannerCard = (tour: PlannerTour) => `
            <a class="planner-preview-card" href="${plannerPath(`/tours/${tour.slug}/`)}">
              <img src="${plannerPath(placeImageMap[tour.place] || tour.coverImage || "/uploads/tour-kerala.svg")}" alt="" loading="lazy" />
              <span>
                <b>${escapePlannerHtml(tour.title)}</b>
                <small>${escapePlannerHtml(tour.place)} · ${tour.duration.nights}N/${tour.duration.days}D</small>
              </span>
            </a>
          `;

          const updatePlannerUrl = () => {
            const params = new URLSearchParams();
            Object.entries(getPlannerState()).forEach(([key, value]) => {
              if (value) params.set(key, value);
            });
            tripPlanner.action = plannerPath(
              `/tours/${params.toString() ? `?${params.toString()}` : ""}`,
            );
          };

          const updatePlanner = () => {
            const signals = Object.values(getPlannerState()).filter(Boolean);
            const matches = signals.length ? plannerTours.filter(tourMatches) : plannerTours;
            filters.forEach((filter) => {
              const label = filter.selectedOptions[0]?.textContent?.trim() || "";
              const valueTarget = laneValues.find(
                (item) => item.dataset.laneValue === filter.name,
              );
              if (valueTarget) valueTarget.textContent = label;
              tripPlanner
                .querySelector<HTMLElement>(`[data-signal][data-field="${filter.name}"]`)
                ?.classList.toggle("has-value", Boolean(filter.value));

              choiceButtons
                .filter((button) => button.dataset.field === filter.name)
                .forEach((button) => {
                  const optionCount = getCountForChoice(
                    filter.name,
                    button.dataset.value || "",
                  );
                  button.classList.toggle(
                    "is-selected",
                    (button.dataset.value || "") === filter.value,
                  );
                  button.dataset.count = `${optionCount} ${optionCount === 1 ? "tour" : "tours"}`;
                  button.setAttribute(
                    "aria-label",
                    `${button.textContent?.trim() || "Any"}: ${optionCount} ${optionCount === 1 ? "tour" : "tours"}`,
                  );
                });
            });
            tripPlanner.classList.toggle("has-signals", signals.length > 0);
            updatePlannerVisual();

            if (count) {
              count.textContent = `${matches.length} ${matches.length === 1 ? "tour" : "tours"} available`;
            }
            if (summary) {
              summary.textContent = signals.length
                ? signals.join(" + ")
                : "Choose a signal to begin.";
            }
            if (submit) {
              submit.textContent = signals.length
                ? matches.length
                  ? `Show ${matches.length} matching ${matches.length === 1 ? "tour" : "tours"}`
                  : "Show nearby ideas"
                : `Explore ${plannerTours.length || ""} tours`.trim();
            }
            if (results) {
              results.innerHTML = matches.slice(0, 3).map(renderPlannerCard).join("");
            }
            updatePlannerUrl();
          };

          filters.forEach((filter) => {
            filter.addEventListener("change", updatePlanner);
          });

          signalToggles.forEach((toggle) => {
            toggle.addEventListener("click", () => {
              const signal = toggle.closest<HTMLElement>("[data-signal]");
              if (!signal) return;
              const willOpen = !signal.classList.contains("is-open");
              const field = signal.dataset.field || "place";

              tripPlanner
                .querySelectorAll<HTMLElement>("[data-signal]")
                .forEach((item) => {
                  item.classList.remove("is-open");
                  item
                    .querySelector<HTMLButtonElement>("[data-signal-toggle]")
                    ?.setAttribute("aria-expanded", "false");
                });

              if (willOpen) {
                signal.classList.add("is-open");
                toggle.setAttribute("aria-expanded", "true");
                updatePlannerVisual(field);
              }
            });
          });

          choiceButtons.forEach((button) => {
            button.addEventListener("click", () => {
              const field = button.dataset.field || "";
              const select = getField(field);
              if (!select) return;
              select.value = button.dataset.value || "";
              select.dispatchEvent(new Event("change", { bubbles: true }));
              button.closest<HTMLElement>("[data-signal]")?.classList.remove("is-open");
              button
                .closest<HTMLElement>("[data-signal]")
                ?.querySelector<HTMLButtonElement>("[data-signal-toggle]")
                ?.setAttribute("aria-expanded", "false");
            });
          });

          document.addEventListener("click", (event) => {
            const openSignal = tripPlanner.querySelector<HTMLElement>("[data-signal].is-open");
            if (!openSignal) return;
            if (openSignal.contains(event.target as Node)) return;
            tripPlanner
              .querySelectorAll<HTMLElement>("[data-signal].is-open")
              .forEach((item) => {
                item.classList.remove("is-open");
                item
                  .querySelector<HTMLButtonElement>("[data-signal-toggle]")
                  ?.setAttribute("aria-expanded", "false");
              });
          });

          document.addEventListener("keydown", (event) => {
            if (event.key !== "Escape") return;
            tripPlanner
              .querySelectorAll<HTMLElement>("[data-signal].is-open")
              .forEach((item) => {
                item.classList.remove("is-open");
                item
                  .querySelector<HTMLButtonElement>("[data-signal-toggle]")
                  ?.setAttribute("aria-expanded", "false");
              });
          });

          fetch(plannerToursUrl)
            .then((response) => response.json() as Promise<PlannerTour[]>)
            .then((tours) => {
              plannerTours = tours;
              updatePlanner();
            })
            .catch(() => {
              if (count) count.textContent = "Tours could not be loaded";
              if (summary) summary.textContent = "Please use the search button.";
            });
        });
      </script>
      <script>
        const duelConcept = document.querySelector<HTMLElement>("[data-fresh-duel]");
        if (duelConcept) {
          const duelCount = duelConcept.querySelector<HTMLElement>("[data-duel-count]");
          const duelMeter = duelConcept.querySelector<HTMLElement>(".duel-meter i");
          const duelTitle = duelConcept.querySelector<HTMLElement>(".duel-stage h3");
          const duelQuestions = [
            "What are you craving first?",
            "How much time do you have?",
            "Which pace feels right?",
          ];
          let duelStep = 0;

          const setDuelState = (button?: HTMLElement) => {
            duelConcept.querySelectorAll("[data-duel-choice]").forEach((item) => {
              item.classList.toggle("is-selected", item === button);
            });
            duelStep = (duelStep + 1) % duelQuestions.length;
            if (duelTitle) duelTitle.textContent = duelQuestions[duelStep];
            if (duelCount && button) {
              const count = button.dataset.count || "4";
              duelCount.textContent = `${count} ${count === "1" ? "tour" : "tours"} still in play`;
            }
            if (duelMeter) duelMeter.style.width = `${duelStep === 0 ? 62 : duelStep === 1 ? 76 : 88}%`;
          };

          duelConcept.querySelectorAll<HTMLElement>("[data-duel-choice]").forEach((button) => {
            button.addEventListener("click", () => setDuelState(button));
          });
          duelConcept.querySelector<HTMLElement>("[data-duel-skip]")?.addEventListener("click", () => {
            setDuelState();
            if (duelCount) duelCount.textContent = "Skipped. 7 tours still in play";
          });
        }

        const coverConcept = document.querySelector<HTMLElement>("[data-fresh-cover]");
        if (coverConcept) {
          const coverTitle = coverConcept.querySelector<HTMLElement>("h3");
          const coverCount = coverConcept.querySelector<HTMLElement>("[data-cover-count]");
          const coverNote = coverConcept.querySelector<HTMLElement>("[data-cover-note]");
          coverConcept.querySelectorAll<HTMLElement>("[data-cover-tag]").forEach((button) => {
            button.addEventListener("click", () => {
              coverConcept.querySelectorAll("[data-cover-tag]").forEach((item) => {
                item.classList.toggle("is-selected", item === button);
              });
              if (coverTitle) coverTitle.textContent = button.dataset.title || "Your Escape";
              if (coverCount) coverCount.textContent = button.dataset.count || "7 routes available";
              if (coverNote) coverNote.textContent = button.dataset.note || "Browse by changing the cover tags.";
            });
          });
        }

        const swipeConcept = document.querySelector<HTMLElement>("[data-fresh-swipe]");
        if (swipeConcept) {
          const cards = Array.from(swipeConcept.querySelectorAll<HTMLElement>("[data-swipe-card]"));
          const note = swipeConcept.querySelector<HTMLElement>("[data-swipe-note]");
          let activeCard = 0;

          const showCard = (nextIndex: number, liked = false) => {
            activeCard = (nextIndex + cards.length) % cards.length;
            cards.forEach((card, index) => {
              card.classList.toggle("is-active", index === activeCard);
              card.style.setProperty("--deck-offset", `${index - activeCard}`);
            });
            const card = cards[activeCard];
            if (note && card) {
              const count = card.dataset.count || "1";
              note.textContent = liked
                ? `${card.dataset.title} saved. ${count} matching ${count === "1" ? "tour" : "tours"} ready.`
                : `${card.dataset.title} is now on top.`;
            }
          };

          swipeConcept.querySelector<HTMLElement>("[data-swipe-skip]")?.addEventListener("click", () => {
            showCard(activeCard + 1);
          });
          swipeConcept.querySelector<HTMLElement>("[data-swipe-like]")?.addEventListener("click", () => {
            showCard(activeCard, true);
          });
          showCard(0);
        }

        const mapConcept = document.querySelector<HTMLElement>("[data-fresh-map]");
        if (mapConcept) {
          const mapCount = mapConcept.querySelector<HTMLElement>("[data-map-count]");
          mapConcept.querySelectorAll<HTMLElement>("[data-map-pin]").forEach((pin) => {
            pin.addEventListener("click", () => {
              mapConcept.querySelectorAll("[data-map-pin]").forEach((item) => {
                item.classList.toggle("is-selected", item === pin);
              });
              const count = pin.dataset.count || "1";
              if (mapCount) mapCount.textContent = `${pin.dataset.place} selected. ${count} ${count === "1" ? "route" : "routes"} ready`;
            });
          });
          mapConcept.querySelectorAll<HTMLElement>("[data-map-filter]").forEach((filter) => {
            filter.addEventListener("click", () => {
              filter.classList.toggle("is-selected");
              const selected = mapConcept.querySelectorAll("[data-map-filter].is-selected").length;
              if (mapCount && selected) mapCount.textContent = `${selected} route clue${selected === 1 ? "" : "s"} selected`;
            });
          });
        }
      </script>
    </div>
  </section>

